---
import "@/styles/global.css";
import { DEFAULT_VARIANTS, PREVIEW_QUERY_KEY } from "@/data/siteDefaults";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Ankush Bhargava — Product Manager & AI Builder",
  description = "Product leader & AI builder with 20+ years in Product, Engineering, and Operations. Shipped $250M B2B platforms, logistics tech, and 3 AI products. SF Bay Area.",
  ogImage = "/images/ankush-bhargava-profile.jpg",
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
const ogImageURL = Astro.site
  ? new URL(ogImage, Astro.site).href
  : ogImage;

const currentPath = Astro.url.pathname;
function navClass(path: string): string {
  const isActive = path === '/' ? currentPath === '/' : currentPath.startsWith(path);
  return isActive
    ? 'text-sm text-[var(--color-accent)] font-medium'
    : 'text-sm hover:text-[var(--color-accent)] transition-colors';
}
---

<!doctype html>
<html lang="en" data-typography="sans" data-creator-mode="false">
  <head>
    <meta charset="UTF-8" />
    <script is:inline define:vars={{ previewKey: PREVIEW_QUERY_KEY }}>
      (function () {
        try {
          var q = new URLSearchParams(window.location.search);
          document.documentElement.setAttribute("data-creator-mode", q.has(previewKey) ? "true" : "false");
        } catch (e) {
          document.documentElement.setAttribute("data-creator-mode", "false");
        }
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("portfolio-theme");
          var theme =
            stored
              ? stored
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "warm";
          if (theme !== "dark" && theme !== "warm") theme = "warm";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute(
            "data-theme",
            window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "warm"
          );
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />
    <!-- Author -->
    <meta name="author" content="Ankush Bhargava" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ankush Bhargava" />
    <meta property="og:locale" content="en_US" />
    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body class="min-h-screen antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[var(--color-bg)]/80 border-b border-[var(--color-border)]">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight" style="font-family: var(--font-heading-sans)">AB</a>
        <div class="flex items-center gap-6">
          <a href="/" class={navClass('/')}>Home</a>
          <a href={currentPath === '/' ? '#journey' : '/journey'} class={navClass('/journey')}>My Journey</a>
          <a href={currentPath === '/' ? '#lab' : '/lab'} class={navClass('/lab')}>My Lab</a>
          <div class="w-px h-5 bg-[var(--color-border)]"></div>
          <button id="theme-toggle" class="text-sm p-1.5 rounded-md hover:bg-[var(--color-bg-secondary)] transition-colors" aria-label="Toggle theme">
            <svg id="icon-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646Z" />
            </svg>
            <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
          </button>
          <div
            id="typo-segment"
            class="flex items-center rounded-lg border border-[var(--color-border)] p-0.5 gap-0.5"
            role="group"
            aria-label="Typography: Modern or Editorial"
          >
            <button
              type="button"
              id="typo-sans"
              class="typo-seg"
              data-typo="sans"
              aria-pressed="true"
              title="Modern: Space Grotesk headings, Inter body"
            >
              Modern
            </button>
            <button
              type="button"
              id="typo-serif"
              class="typo-seg"
              data-typo="serif"
              aria-pressed="false"
              title="Editorial: Playfair Display headings, Inter body"
            >
              Editorial
            </button>
          </div>
        </div>
      </div>
    </nav>

    <div id="variant-switcher" class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-full shadow-lg px-4 py-2 flex items-center gap-3 text-xs">
      <span class="text-[var(--color-text-secondary)] font-medium">Variant:</span>
      <div id="variant-buttons" class="flex gap-1"></div>
    </div>

    <main class="pt-14">
      <slot />
    </main>

    <script type="application/json" id="portfolio-default-variants" set:html={JSON.stringify(DEFAULT_VARIANTS)}></script>

    <script is:inline>
      (function() {
        var theme = document.documentElement.getAttribute('data-theme') || 'warm';
        var creator = document.documentElement.getAttribute('data-creator-mode') === 'true';
        var savedTypo = creator
          ? (localStorage.getItem('portfolio-typography') || 'sans')
          : 'sans';
        document.documentElement.setAttribute('data-typography', savedTypo);
        function syncTypoButtons() {
          var sans = document.getElementById('typo-sans');
          var serif = document.getElementById('typo-serif');
          var mode = document.documentElement.getAttribute('data-typography') || 'sans';
          if (!sans || !serif) return;
          sans.setAttribute('aria-pressed', mode === 'sans' ? 'true' : 'false');
          serif.setAttribute('aria-pressed', mode === 'serif' ? 'true' : 'false');
        }
        syncTypoButtons();
        var moon = document.getElementById('icon-moon');
        var sun = document.getElementById('icon-sun');
        if (moon && sun) {
          if (theme === 'dark') { moon.classList.add('hidden'); sun.classList.remove('hidden'); }
          else { moon.classList.remove('hidden'); sun.classList.add('hidden'); }
        }
      })();
    </script>
    <script>
      function updateThemeIcons(theme: string) {
        const moon = document.getElementById('icon-moon');
        const sun = document.getElementById('icon-sun');
        if (moon && sun) {
          if (theme === 'dark') {
            moon.classList.add('hidden');
            sun.classList.remove('hidden');
          } else {
            moon.classList.remove('hidden');
            sun.classList.add('hidden');
          }
        }
      }

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'warm' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('portfolio-theme', next);
        updateThemeIcons(next);
      });

      const colorSchemeMedia = window.matchMedia('(prefers-color-scheme: dark)');
      function applySystemThemeWhenNoSavedChoice() {
        try {
          if (localStorage.getItem('portfolio-theme')) return;
        } catch {
          return;
        }
        const next = colorSchemeMedia.matches ? 'dark' : 'warm';
        document.documentElement.setAttribute('data-theme', next);
        updateThemeIcons(next);
      }
      colorSchemeMedia.addEventListener('change', applySystemThemeWhenNoSavedChoice);

      function setTypography(mode: 'sans' | 'serif') {
        document.documentElement.setAttribute('data-typography', mode);
        localStorage.setItem('portfolio-typography', mode);
        document.getElementById('typo-sans')?.setAttribute('aria-pressed', mode === 'sans' ? 'true' : 'false');
        document.getElementById('typo-serif')?.setAttribute('aria-pressed', mode === 'serif' ? 'true' : 'false');
      }

      document.getElementById('typo-sans')?.addEventListener('click', () => setTypography('sans'));
      document.getElementById('typo-serif')?.addEventListener('click', () => setTypography('serif'));

      function setupVariantSwitcher() {
        if (document.documentElement.getAttribute('data-creator-mode') !== 'true') {
          return;
        }

        let defaultVariants: Record<string, string> = {};
        try {
          const el = document.getElementById('portfolio-default-variants');
          if (el?.textContent) defaultVariants = JSON.parse(el.textContent) as Record<string, string>;
        } catch {
          /* ignore */
        }

        const sections = document.querySelectorAll('[data-variant-group]');
        const groups = new Map<string, string[]>();

        sections.forEach((section) => {
          const group = section.getAttribute('data-variant-group')!;
          const variant = section.getAttribute('data-variant')!;
          if (!groups.has(group)) groups.set(group, []);
          groups.get(group)!.push(variant);
        });

        const container = document.getElementById('variant-buttons');
        const switcher = document.getElementById('variant-switcher');
        if (!container || groups.size === 0) {
          switcher?.classList.add('hidden');
          return;
        }

        const state: Record<string, string> = {};

        groups.forEach((variants, group) => {
          const saved = localStorage.getItem(`variant-${group}`);
          const fallback = defaultVariants[group];
          const fromDefault = fallback && variants.includes(fallback) ? fallback : variants[0];
          state[group] = saved && variants.includes(saved) ? saved : fromDefault!;

          const groupDiv = document.createElement('div');
          groupDiv.className = 'flex items-center gap-1 px-2 border-r border-[var(--color-border)] last:border-r-0';

          const label = document.createElement('span');
          label.className = 'text-[var(--color-text-secondary)] mr-1';
          label.textContent = group + ':';
          groupDiv.appendChild(label);

          variants.forEach((v) => {
            const btn = document.createElement('button');
            btn.textContent = v;
            btn.className = 'px-2 py-0.5 rounded-full transition-colors';
            btn.addEventListener('click', () => {
              state[group] = v;
              localStorage.setItem(`variant-${group}`, v);
              updateVariants();
            });
            groupDiv.appendChild(btn);
          });

          container.appendChild(groupDiv);
        });

        function updateVariants() {
          sections.forEach((section) => {
            const group = section.getAttribute('data-variant-group')!;
            const variant = section.getAttribute('data-variant')!;
            const isActive = state[group] === variant;
            section.classList.toggle('hidden', !isActive);
          });
          container?.querySelectorAll('div').forEach((groupDiv) => {
            const groupLabel = groupDiv.querySelector('span')?.textContent?.replace(':', '');
            if (!groupLabel) return;
            groupDiv.querySelectorAll('button').forEach((btn) => {
              const isActive = state[groupLabel] === btn.textContent;
              btn.classList.toggle('bg-[var(--color-accent)]', isActive);
              btn.classList.toggle('text-white', isActive);
            });
          });
        }

        updateVariants();
      }

      setupVariantSwitcher();
    </script>
  </body>
</html>
