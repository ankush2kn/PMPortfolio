---
import { principles } from "@/data/portfolio";
---

<!-- Option A: Minimal Grid -->
<section class="py-20 px-6" id="principles">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-10 text-center">
      Approach & Mindset
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {principles.map((p, i) => (
        <div
          class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-accent)] transition-colors duration-300"
          style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.08 * i}s both;`}
        >
          <h3 class="text-sm font-bold leading-snug">{p.title}</h3>
          <p class="text-xs text-[var(--color-text-secondary)] mt-2 leading-relaxed">{p.context}</p>
        </div>
      ))}
    </div>
  </div>
</section>
