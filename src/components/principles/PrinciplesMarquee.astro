---
import { principles } from "@/data/portfolio";

const doubled = [...principles, ...principles];
---

<!-- Option B: Marquee / Scrolling Strip -->
<section class="pt-8 pb-8 overflow-hidden border-y border-[var(--color-border)]" id="principles">
  <h2 class="text-base uppercase tracking-widest text-[var(--color-text-secondary)] mb-8 text-center">
    Approach & Mindset
  </h2>
  <div class="relative principles-marquee-wrap">
    <div class="principles-marquee-track flex gap-10 whitespace-nowrap" style="animation: ticker-scroll 45s linear infinite;">
      {doubled.map((p) => (
        <div class="flex items-baseline gap-3 shrink-0">
          <span class="text-base md:text-lg font-bold text-[var(--color-accent)]">{p.title}</span>
          <span class="text-sm text-[var(--color-text-secondary)] max-w-[14rem] hidden sm:inline">{p.context}</span>
          <span class="text-[var(--color-border)]">|</span>
        </div>
      ))}
      <div class="shrink-0 w-10" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .principles-marquee-track {
    backface-visibility: hidden;
  }

  .principles-marquee-wrap:hover .principles-marquee-track {
    animation-play-state: paused;
  }
</style>
