---
import { principles } from "@/data/portfolio";

const rotations = [-2.5, 3, -1.5, 2, -3, 1.5];
---

<!-- Option C: Handwritten / sticky-note board -->
<section class="pt-10 pb-10 px-6" id="principles">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-12 text-center">
      Approach & Mindset
    </h2>
    <div class="relative min-h-[380px] md:min-h-[320px] rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-8 md:p-10 overflow-hidden">
      <!-- Cork board texture hint -->
      <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(circle at 20% 30%, currentColor 1px, transparent 1px); background-size: 12px 12px;"></div>

      <div class="relative flex flex-wrap justify-center gap-6 md:gap-8 items-start">
        {principles.map((p, i) => (
          <div
            class="w-[min(100%,14rem)] bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-sm p-4 shadow-md shadow-[var(--color-card-shadow)] hover:z-10 hover:scale-[1.02] transition-transform duration-200"
            style={`transform: rotate(${rotations[i % rotations.length]}deg); animation: fadeInUp 0.6s var(--ease-out-expo) ${0.1 * i}s both;`}
          >
            <!-- Pin -->
            <div class="absolute -top-1.5 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-[var(--color-accent)] shadow-sm ring-2 ring-white/20"></div>
            <h3 class="text-sm font-bold leading-snug pt-1">{p.title}</h3>
            <p class="text-xs text-[var(--color-text-secondary)] mt-2 leading-relaxed italic">{p.context}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
