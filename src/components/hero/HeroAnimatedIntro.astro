---
import SketchAnkush from "@/components/characters/SketchAnkush.astro";
import { profile } from "@/data/portfolio";
---

<!-- Hero Option A: "The Animated Introduction" -->
<section class="min-h-[calc(100vh-3.5rem)] flex flex-col items-center justify-center px-6 text-center relative overflow-hidden">
  <div class="flex flex-col items-center gap-8 max-w-2xl">
    <!-- Character slides in -->
    <div class="character-entrance" style="animation: fadeInUp 1s var(--ease-out-expo) both;">
      <SketchAnkush pose="wave" class="w-32 h-auto" />
    </div>

    <!-- Name draws in with handwritten feel -->
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight" style="animation: fadeInUp 1s var(--ease-out-expo) 0.3s both;">
      {profile.name}
    </h1>

    <!-- Rotating taglines with typewriter effect -->
    <div class="h-8 relative w-full max-w-lg" style="animation: fadeIn 1s ease-out 0.8s both;">
      <p class="typewriter-text text-lg md:text-xl text-[var(--color-text-secondary)]" id="hero-a-tagline">
        {profile.taglines[0]}
      </p>
    </div>

    <!-- Available badge -->
    <div class="flex items-center gap-2 mt-2" style="animation: fadeInUp 1s var(--ease-out-expo) 1.2s both;">
      <span class="relative flex h-2.5 w-2.5">
        <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-available)] opacity-75" style="animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[var(--color-available)]"></span>
      </span>
      <span class="text-sm font-medium text-[var(--color-available)]">{profile.availability}</span>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-4 mt-4" style="animation: fadeInUp 1s var(--ease-out-expo) 1.5s both;">
      <a href="#impact" class="px-6 py-2.5 bg-[var(--color-accent)] text-white rounded-full text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
        See My Work
      </a>
      <a href={profile.linkedin} target="_blank" rel="noopener" class="p-2.5 rounded-full border border-[var(--color-border)] hover:bg-[var(--color-bg-secondary)] transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" style="animation: float 2s ease-in-out infinite, fadeIn 1s ease-out 2s both;">
    <svg class="w-6 h-6 text-[var(--color-text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>

<script>
  const taglines = [
    "20 years building products. Now building with AI.",
    "Enterprise scale meets startup speed.",
    "From $250M platforms to agentic workflows.",
  ];
  let taglineIndex = 0;
  const el = document.getElementById("hero-a-tagline");
  if (el) {
    setInterval(() => {
      taglineIndex = (taglineIndex + 1) % taglines.length;
      el.style.opacity = "0";
      el.style.transform = "translateY(8px)";
      setTimeout(() => {
        el.textContent = taglines[taglineIndex];
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
      }, 300);
    }, 3500);
    el.style.transition = "opacity 0.3s, transform 0.3s";
  }
</script>
