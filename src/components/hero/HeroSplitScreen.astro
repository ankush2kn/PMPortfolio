---
import { profile } from "@/data/portfolio";
---

<!-- Hero Option B: "The Split Screen" (content-focused, no illustration) -->
<section class="min-h-0 py-8 md:py-10 flex items-center justify-center px-6">
  <div class="max-w-2xl w-full space-y-6 text-center md:text-left mx-auto" style="animation: fadeInUp 1s var(--ease-out-expo) both;">
    <div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight">{profile.name}</h1>
      <p class="text-lg text-[var(--color-text-secondary)] mt-3 max-w-md md:max-w-none">
        Entrepreneurial product leader building at the intersection of enterprise scale and AI innovation.
      </p>
    </div>

    <!-- Headline metrics -->
    <div class="grid grid-cols-3 gap-4 max-w-md mx-auto md:mx-0">
      <div class="metric-counter" style="animation: count-up 0.8s var(--ease-out-expo) 0.2s both;">
        <span class="text-3xl md:text-4xl font-bold text-[var(--color-accent)]">20+</span>
        <span class="text-xs text-[var(--color-text-secondary)] mt-1 block">Years</span>
      </div>
      <div class="metric-counter" style="animation: count-up 0.8s var(--ease-out-expo) 0.35s both;">
        <span class="text-3xl md:text-4xl font-bold text-[var(--color-accent)]">$250M</span>
        <span class="text-xs text-[var(--color-text-secondary)] mt-1 block">Products Built</span>
      </div>
      <div class="metric-counter" style="animation: count-up 0.8s var(--ease-out-expo) 0.5s both;">
        <span class="text-3xl md:text-4xl font-bold text-[var(--color-accent)]">2</span>
        <span class="text-xs text-[var(--color-text-secondary)] mt-1 block">Patents</span>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center gap-4 pt-2 justify-center md:justify-start">
      <a href="#impact" class="px-6 py-2.5 bg-[var(--color-accent)] text-white rounded-full text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
        See My Work
      </a>
      <a href={profile.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        Connect on LinkedIn
      </a>
    </div>
  </div>
</section>
