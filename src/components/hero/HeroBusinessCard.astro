---
import SketchAnkush from "@/components/characters/SketchAnkush.astro";
import { profile } from "@/data/portfolio";
---

<!-- Hero Option C: "The Business Card" - Ultra-minimal, typography-driven -->
<section class="min-h-[calc(100vh-3.5rem)] flex flex-col items-center justify-center px-6 text-center relative">
  <div class="space-y-6" style="animation: fadeIn 1.2s ease-out both;">
    <h1 class="text-6xl md:text-8xl font-bold tracking-tighter" style="animation: fadeInUp 1s var(--ease-out-expo) 0.2s both;">
      {profile.name}
    </h1>

    <!-- Typewriter tagline -->
    <div class="overflow-hidden" style="animation: fadeIn 1s ease-out 0.8s both;">
      <p class="text-lg md:text-xl text-[var(--color-text-secondary)] border-r-2 border-[var(--color-accent)] inline-block whitespace-nowrap overflow-hidden"
         style="animation: typewriter 2s steps(40) 1s both, blink-caret 0.75s step-end infinite;"
         id="hero-c-typewriter">
        Product Leader &middot; AI Builder &middot; Patent Holder
      </p>
    </div>

    <div class="flex items-center justify-center gap-2 mt-4" style="animation: fadeInUp 1s var(--ease-out-expo) 2.5s both;">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-available)] opacity-75" style="animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-available)]"></span>
      </span>
      <span class="text-sm text-[var(--color-available)]">{profile.availability}</span>
    </div>
  </div>

  <!-- Character peeking from bottom-right -->
  <div class="absolute bottom-0 right-8 md:right-16" style="animation: fadeInUp 0.8s var(--ease-out-expo) 1.5s both;">
    <div class="translate-y-16">
      <SketchAnkush pose="point" class="w-24 md:w-32 h-auto" />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" style="animation: float 2s ease-in-out infinite, fadeIn 1s ease-out 3s both;">
    <div class="flex flex-col items-center gap-1 text-[var(--color-text-secondary)]">
      <span class="text-[10px] uppercase tracking-widest">Scroll</span>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7"/>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes ping {
    75%, 100% { transform: scale(2); opacity: 0; }
  }
</style>
