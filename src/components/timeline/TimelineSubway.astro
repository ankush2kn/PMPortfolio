---
import { career, careerReverseChronological } from "@/data/portfolio";
import { samplePositionsAlongPolyline, SUBWAY_ROUTE_VERTICES } from "@/lib/careerTimelineLayout";
import { careerCompanyShort, careerStr, pickCareerDomainColor } from "@/lib/careerDisplay";
import { CAREER_DOMAIN_HEX, careerDomainsCsv, careerEntryPrimaryDomain } from "@/lib/careerDomains";

const careerCount = career.length;
const positionsChrono = samplePositionsAlongPolyline(SUBWAY_ROUTE_VERTICES, careerCount);

const lineNames = [
  { domain: "engineering", label: "Engineering Line", color: "#6366f1" },
  { domain: "startup", label: "Startup Line", color: "#f59e0b" },
  { domain: "operations", label: "Operations Line", color: "#10b981" },
  { domain: "product", label: "Product Line", color: "#3b82f6" },
  { domain: "b2b", label: "B2B Line", color: "#0d9488" },
  { domain: "b2c", label: "B2C Line", color: "#f43f5e" },
  { domain: "ai", label: "AI Line", color: "#e88c4f" },
];
---

<!-- Timeline Option 1: "The Subway Map" - Career as a metro route -->
<div class="max-w-5xl mx-auto">
  <!-- Legend -->
  <div class="flex flex-wrap gap-4 mb-10 justify-center">
    {lineNames.map((line) => (
      <div class="flex items-center gap-2">
        <div class="w-4 h-1 rounded-full" style={`background-color: ${line.color};`}></div>
        <span class="text-xs text-[var(--color-text-secondary)]">{line.label}</span>
      </div>
    ))}
  </div>

  <!-- Subway map as SVG -->
  <div class="relative">
    <svg viewBox="0 0 900 600" class="w-full" xmlns="http://www.w3.org/2000/svg">
      <!-- Route lines -->
      <!-- Engineering line (left section) -->
      <path d="M50 300 L200 300" stroke="#6366f1" stroke-width="6" fill="none" stroke-linecap="round"
            class="subway-line" style="stroke-dasharray: 200; stroke-dashoffset: 200; animation: draw 1s ease-out 0.2s forwards;"/>
      <!-- Startup line (continues, with a curve) -->
      <path d="M200 300 L300 300 Q350 300 370 260 L400 200" stroke="#f59e0b" stroke-width="6" fill="none" stroke-linecap="round"
            class="subway-line" style="stroke-dasharray: 300; stroke-dashoffset: 300; animation: draw 1s ease-out 0.5s forwards;"/>
      <!-- Operations line (from startup, curves back) -->
      <path d="M400 200 Q420 160 460 180 L550 280 Q570 300 600 300" stroke="#10b981" stroke-width="6" fill="none" stroke-linecap="round"
            class="subway-line" style="stroke-dasharray: 300; stroke-dashoffset: 300; animation: draw 1s ease-out 0.8s forwards;"/>
      <!-- Product line (main horizontal) -->
      <path d="M600 300 L780 300" stroke="#3b82f6" stroke-width="6" fill="none" stroke-linecap="round"
            class="subway-line" style="stroke-dasharray: 200; stroke-dashoffset: 200; animation: draw 1s ease-out 1.1s forwards;"/>
      <!-- AI line (ascends from product) -->
      <path d="M780 300 Q810 300 830 260 L850 200" stroke="#e88c4f" stroke-width="6" fill="none" stroke-linecap="round"
            class="subway-line" style="stroke-dasharray: 150; stroke-dashoffset: 150; animation: draw 1s ease-out 1.4s forwards;"/>

      <!-- Stations -->
      {careerReverseChronological.map((entry, i) => {
        const pos = positionsChrono[careerCount - 1 - i]!;
        const color = pickCareerDomainColor(CAREER_DOMAIN_HEX, careerEntryPrimaryDomain(entry));
        const short = careerCompanyShort(entry.company);
        const per = careerStr(entry.period);
        return (
          <g
            class="subway-station cursor-pointer"
            data-station={entry.id}
            data-career-entry
            data-career-domains={careerDomainsCsv(entry)}
            style={`animation: fadeIn 0.5s ease-out ${0.3 * i + 0.5}s both;`}
          >
            {/* Station circle */}
            <circle cx={pos.x} cy={pos.y} r="10" fill="var(--color-card-bg)" stroke={color} stroke-width="3"/>
            <circle cx={pos.x} cy={pos.y} r="4" fill={color}/>
            {/* Station label */}
            {short && (
            <text x={pos.x} y={pos.y - (per ? 20 : 14)} text-anchor="middle" fill="currentColor" font-size="11" font-weight="600">
              {short}
            </text>
            )}
            {per && (
            <text x={pos.x} y={pos.y - (short ? 8 : 14)} text-anchor="middle" fill="currentColor" font-size="8" opacity="0.6">
              {per}
            </text>
            )}
            {/* Key metric below */}
            {careerStr(entry.keyMetric) && (
              <text x={pos.x} y={pos.y + 25} text-anchor="middle" fill={color} font-size="10" font-weight="700">
                {entry.keyMetric}
              </text>
            )}
          </g>
        );
      })}

      <!-- Education/MBA marker -->
      <g style="animation: fadeIn 0.5s ease-out 1s both;">
        <rect x="440" y="360" width="80" height="25" rx="4" fill="none" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4"/>
        <text x="480" y="377" text-anchor="middle" fill="currentColor" font-size="9" opacity="0.5">MBA 2012</text>
      </g>
    </svg>
  </div>

  <!-- Station details (shown on hover/click) -->
  <div id="subway-detail" class="mt-8 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-6 hidden">
    <div id="subway-detail-content"></div>
  </div>
</div>

<script define:vars={{ career: JSON.stringify(careerReverseChronological), lineColors: JSON.stringify(CAREER_DOMAIN_HEX) }}>
  const careerData = JSON.parse(career);
  const colors = JSON.parse(lineColors);

  function careerStrClient(v) {
    if (v == null || typeof v !== "string") return null;
    const t = v.trim();
    return t.length > 0 ? t : null;
  }

  function pickCareerDomainColorClient(entry) {
    const first = Array.isArray(entry.domains) && entry.domains.length > 0 ? entry.domains[0] : null;
    if (first && colors[first]) return colors[first];
    return "#888888";
  }

  function escHtml(s) {
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function escAttr(s) {
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/"/g, "&quot;");
  }

  const EXTERNAL_TAB_ICON =
    '<svg class="career-subway-company-ext" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg><span class="sr-only"> Opens in new tab</span>';

  document.querySelectorAll(".subway-station").forEach((station) => {
    station.addEventListener("click", () => {
      const id = station.getAttribute("data-station");
      const entry = careerData.find((e) => e.id === id);
      if (!entry) return;

      const detail = document.getElementById("subway-detail");
      const content = document.getElementById("subway-detail-content");
      if (!detail || !content) return;

      const domainColor = pickCareerDomainColorClient(entry);
      const companyName = careerStrClient(entry.company);
      const companyUrl = careerStrClient(entry.companyUrl);
      const companyHtml =
        companyName &&
        (companyUrl
          ? `<a href="${escAttr(companyUrl)}" target="_blank" rel="noopener noreferrer" class="career-subway-company-link">${escHtml(companyName)}${EXTERNAL_TAB_ICON}</a>`
          : escHtml(companyName));
      const metaTail = [careerStrClient(entry.period), careerStrClient(entry.location)].filter(Boolean).map(escHtml);
      const metaSegments = [companyHtml, ...metaTail].filter(Boolean);
      const metaHtml =
        metaSegments.length > 0
          ? `<p class="text-sm" style="color: var(--color-text-secondary);">${metaSegments.join(" &middot; ")}</p>`
          : "";

      const title = careerStrClient(entry.title);
      const titleHtml = title ? `<h3 class="text-lg font-bold">${escHtml(title)}</h3>` : "";

      const key = careerStrClient(entry.keyMetric);
      const keyHtml = key
        ? `<span class="text-xl font-bold shrink-0" style="color: ${domainColor};">${escHtml(key)}</span>`
        : "";

      const hl = Array.isArray(entry.highlights)
        ? entry.highlights.map((h) => careerStrClient(h)).filter(Boolean)
        : [];
      const listHtml = hl.length > 0
        ? `<ul class="space-y-1.5">${hl.map((h) => `<li class="text-sm" style="color: var(--color-text-secondary);">&#8226; ${escHtml(h)}</li>`).join("")}</ul>`
        : "";

      function normalizeCareerImagesClient(images) {
        if (!Array.isArray(images)) return [];
        const out = [];
        for (const raw of images) {
          if (typeof raw === "string") {
            const s = careerStrClient(raw);
            if (s) out.push({ src: s });
            continue;
          }
          if (raw && typeof raw === "object" && typeof raw.src === "string") {
            const src = careerStrClient(raw.src);
            if (!src) continue;
            const href = careerStrClient(raw.href);
            out.push(href ? { src, href } : { src });
          }
        }
        return out;
      }

      const imgItems = normalizeCareerImagesClient(entry.images);
      const labelForImgs = careerStrClient(entry.company) ?? careerStrClient(entry.title) ?? entry.id;
      const thumbClass =
        "inline-flex w-10 h-10 shrink-0 items-center justify-center overflow-hidden rounded-md border border-[var(--color-border)] bg-[var(--color-bg-secondary)] hover:border-[var(--color-accent)]";
      const thumbImgClass = "max-h-full max-w-full object-contain block";
      const thumbsHtml =
        imgItems.length > 0
          ? `<div class="flex flex-wrap gap-1.5 mt-4" role="group" aria-label="Photos for ${escAttr(labelForImgs)}">${imgItems
              .map((item, idx) =>
                item.href
                  ? `<a href="${escAttr(item.href)}" target="_blank" rel="noopener noreferrer" class="${thumbClass}" aria-label="Open related link in new tab — image ${idx + 1} — ${escAttr(labelForImgs)}"><img src="${escAttr(item.src)}" alt="" width="40" height="40" class="${thumbImgClass}" loading="lazy" decoding="async" /></a>`
                  : `<button type="button" class="career-thumb-btn ${thumbClass}" data-career-lightbox="${escAttr(item.src)}" aria-label="View image ${idx + 1} full size — ${escAttr(labelForImgs)}"><img src="${escAttr(item.src)}" alt="" width="40" height="40" class="${thumbImgClass}" loading="lazy" decoding="async" /></button>`,
              )
              .join("")}</div>`
          : "";

      const leftBlock = titleHtml || metaHtml;
      const topRow = leftBlock
        ? `<div class="flex items-start justify-between mb-3 gap-4"><div>${titleHtml}${metaHtml}</div>${keyHtml}</div>`
        : keyHtml
          ? `<div class="flex items-start justify-between mb-3 gap-4"><div></div>${keyHtml}</div>`
          : "";

      detail.classList.remove("hidden");
      content.innerHTML = topRow + listHtml + thumbsHtml;
    });
  });
</script>

<style is:global>
  .career-subway-company-link {
    color: inherit;
    text-underline-offset: 2px;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .career-subway-company-link:hover {
    text-decoration: underline;
    color: var(--color-accent);
  }
  .career-subway-company-ext {
    flex-shrink: 0;
    width: 0.85em;
    height: 0.85em;
    opacity: 0.7;
    vertical-align: middle;
  }
</style>
