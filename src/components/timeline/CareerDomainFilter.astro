---
import { career } from "@/data/portfolio";
import { CAREER_DOMAIN_LABEL, CAREER_DOMAIN_ORDER, uniqueCareerDomainsPresent } from "@/lib/careerDomains";

const present = uniqueCareerDomainsPresent(career);
const pills = CAREER_DOMAIN_ORDER.filter((id) => present.includes(id));
---

<div
  class="flex flex-wrap items-center justify-center gap-2 mt-10 md:mt-10 max-w-2xl mx-auto"
  data-journey-domain-filter-bar
  role="toolbar"
  aria-label="Filter journey by domain"
>
  <button
    type="button"
    data-journey-domain-pill
    data-domain="overall"
    aria-pressed="true"
    class="journey-domain-pill inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-card-bg)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] transition-colors"
  >
    <span
      class="inline-flex shrink-0 items-center justify-center text-green-600 dark:text-green-500"
      data-journey-pill-check
      aria-hidden="true"
    >
      <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </span>
    Overall
  </button>
  {
    pills.map((id) => (
      <button
        type="button"
        data-journey-domain-pill
        data-domain={id}
        aria-pressed="false"
        class="journey-domain-pill inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-card-bg)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] transition-colors"
      >
        <span
          class="hidden shrink-0 items-center justify-center text-green-600 dark:text-green-500"
          data-journey-pill-check
          aria-hidden="true"
        >
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </span>
        {CAREER_DOMAIN_LABEL[id]}
      </button>
    ))
  }
</div>

<script>
  let journeyFilterActiveDomain: string | null = null;

  function applyJourneyDomainFilter(activeDomain: string | null) {
    journeyFilterActiveDomain = activeDomain;
    document.querySelectorAll("[data-career-entry]").forEach((el) => {
      if (!(el instanceof HTMLElement)) return;
      const raw = el.dataset.careerDomains ?? "";
      const set = raw.split(",").map((s) => s.trim()).filter(Boolean);
      const show = activeDomain === null || set.includes(activeDomain);
      el.classList.toggle("hidden", !show);
    });

    document.querySelectorAll("[data-career-highlight]").forEach((el) => {
      if (!(el instanceof HTMLElement)) return;
      const raw = el.dataset.highlightTags ?? "";
      const tags = raw.split(",").map((s) => s.trim()).filter(Boolean);
      const show =
        activeDomain === null ? tags.includes("overall") : tags.includes(activeDomain);
      el.classList.toggle("hidden", !show);
    });

    document.querySelectorAll("[data-career-highlights-list]").forEach((ul) => {
      if (!(ul instanceof HTMLElement)) return;
      const items = ul.querySelectorAll("[data-career-highlight]");
      const anyVisible = Array.from(items).some(
        (li) => li instanceof HTMLElement && !li.classList.contains("hidden"),
      );
      ul.classList.toggle("hidden", items.length > 0 && !anyVisible);
    });

    document.querySelectorAll("[data-journey-domain-pill]").forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;
      const d = btn.dataset.domain ?? "";
      const isOverallPill = d === "overall";
      const pressed = activeDomain === null ? isOverallPill : d === activeDomain;
      btn.setAttribute("aria-pressed", pressed ? "true" : "false");
      const check = btn.querySelector("[data-journey-pill-check]");
      if (check instanceof HTMLElement) {
        check.classList.toggle("hidden", !pressed);
        check.classList.toggle("inline-flex", pressed);
      }
    });

    window.dispatchEvent(new CustomEvent("journey-career-filter-changed"));
  }

  function onFilterClick(e: MouseEvent) {
    const t = e.target;
    if (!(t instanceof Element)) return;
    const btn = t.closest("[data-journey-domain-pill]");
    if (!(btn instanceof HTMLButtonElement)) return;
    const d = btn.dataset.domain ?? "overall";
    if (d === "overall") {
      applyJourneyDomainFilter(null);
      return;
    }
    if (journeyFilterActiveDomain === d) {
      applyJourneyDomainFilter(null);
      return;
    }
    applyJourneyDomainFilter(d);
  }

  function initJourneyFilter() {
    applyJourneyDomainFilter(null);
  }

  const g = globalThis as typeof globalThis & { __journeyDomainFilterInit?: boolean };
  if (!g.__journeyDomainFilterInit) {
    g.__journeyDomainFilterInit = true;
    document.addEventListener("click", onFilterClick);
    document.addEventListener("astro:page-load", initJourneyFilter);
  }

  requestAnimationFrame(initJourneyFilter);
</script>
