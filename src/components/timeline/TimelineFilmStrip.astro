---
import { careerReverseChronological } from "@/data/portfolio";
import {
  careerHighlightDisplayText,
  careerHighlightTagsCsv,
  careerHighlightsPreview,
  careerPeriodLocation,
  careerStr,
  pickCareerDomainColor,
} from "@/lib/careerDisplay";
import { CAREER_DOMAIN_HEX, careerDomainsCsv, careerEntryPrimaryDomain } from "@/lib/careerDomains";
import CareerCardThumbnails from "@/components/timeline/CareerCardThumbnails.astro";
import CareerCompanyLine from "@/components/timeline/CareerCompanyLine.astro";
---

<!-- Timeline Option 5: "The Film Strip / Chapters" - Horizontal scroll cards -->
<div class="relative">
  <!-- Horizontal scroll container -->
  <div class="overflow-x-auto pb-6 scrollbar-hide" id="film-strip">
    <div class="flex gap-6 px-6 min-w-max">
      {careerReverseChronological.map((entry, i) => {
        const primary = careerEntryPrimaryDomain(entry);
        const color = pickCareerDomainColor(CAREER_DOMAIN_HEX, primary);
        const periodLoc = careerPeriodLocation(entry.period, entry.location);
        const preview = careerHighlightsPreview(entry.highlights);
        const cardLabel = careerStr(entry.company) ?? careerStr(entry.title) ?? entry.id;
        return (
        <div
          class="w-72 shrink-0 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl group"
          data-career-entry
          data-career-domains={careerDomainsCsv(entry)}
          style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.12 * i}s both;`}
        >
          <!-- Header band (accent from primary domain) -->
          <div class="h-24 flex items-end justify-end p-5 relative" style={`background: linear-gradient(135deg, ${color}15, ${color}05);`}>
            <span class="text-4xl font-black opacity-10" style={`color: ${color};`}>
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>

          <!-- Content -->
          <div class="p-5 space-y-3">
            <div>
              {careerStr(entry.title) && (
              <h3 class="text-sm font-bold text-[var(--color-text-secondary)]">{entry.title}</h3>
              )}
              <CareerCompanyLine
                company={entry.company}
                companyUrl={entry.companyUrl}
                textClass="text-sm font-bold text-[var(--color-text-secondary)]"
              />
              {periodLoc && (
              <p class="text-xs text-[var(--color-text-secondary)]">{periodLoc}</p>
              )}
            </div>

            {careerStr(entry.keyMetric) && (
              <div class="bg-[var(--color-bg-secondary)] rounded-lg px-3 py-2">
                <span class="text-lg font-bold">{entry.keyMetric}</span>
              </div>
            )}

            {preview.length > 0 && (
            <ul class="space-y-2" data-career-highlights-list>
              {preview.map((h) => (
                <li
                  class="flex flex-row items-stretch gap-2 text-[11px] text-[var(--color-text-secondary)]"
                  data-career-highlight
                  data-highlight-tags={careerHighlightTagsCsv(h.domains)}
                >
                  <span
                    class="w-0.5 shrink-0 rounded-full self-stretch min-h-[1em] opacity-[0.5]"
                    style={`background-color: ${color}`}
                    aria-hidden="true"
                  />
                  <span class="min-w-0 flex-1">{careerHighlightDisplayText(h.text)}</span>
                </li>
              ))}
            </ul>
            )}
            <CareerCardThumbnails images={entry.images} label={cardLabel} align="start" />
          </div>
        </div>
        );
      })}
    </div>
  </div>

  <!-- Scroll indicators -->
  <div class="flex justify-center gap-2 mt-4">
    <button id="film-prev" class="p-2 rounded-full border border-[var(--color-border)] hover:bg-[var(--color-bg-secondary)] transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
      </svg>
    </button>
    <div class="flex items-center gap-1">
      {careerReverseChronological.map((_, i) => (
        <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-border)] film-dot" data-idx={i}></div>
      ))}
    </div>
    <button id="film-next" class="p-2 rounded-full border border-[var(--color-border)] hover:bg-[var(--color-bg-secondary)] transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
    </button>
  </div>

  <!-- Keyboard hint -->
  <p class="text-[10px] text-[var(--color-text-secondary)] text-center mt-2 opacity-50">
    Drag to scroll or use arrow keys
  </p>
</div>

<script>
  const strip = document.getElementById('film-strip');
  const prev = document.getElementById('film-prev');
  const next = document.getElementById('film-next');
  const cardWidth = 288 + 24;

  prev?.addEventListener('click', () => {
    strip?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
  });
  next?.addEventListener('click', () => {
    strip?.scrollBy({ left: cardWidth, behavior: 'smooth' });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
