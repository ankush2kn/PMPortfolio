---
import { careerReverseChronological } from "@/data/portfolio";
import {
  careerHighlightDisplayText,
  careerHighlightTagsCsv,
  careerHighlightsPreview,
  careerStr,
  careerYearStartEndLabels,
  pickCareerDomainColor,
} from "@/lib/careerDisplay";
import { CAREER_DOMAIN_HEX, careerDomainsCsv, careerEntryPrimaryDomain } from "@/lib/careerDomains";
import CareerCardThumbnails from "@/components/timeline/CareerCardThumbnails.astro";
import CareerCompanyLine from "@/components/timeline/CareerCompanyLine.astro";
---

<!-- Timeline Option 3: "Scroll-Driven Vertical Timeline" - Central spine, alternating cards -->
<div class="relative max-w-4xl mx-auto">
  <div class="absolute left-1/2 top-0 bottom-0 w-px bg-[var(--color-border)] -translate-x-1/2 hidden md:block"></div>
  <div class="absolute left-6 top-0 bottom-0 w-px bg-[var(--color-border)] md:hidden"></div>

  <div class="vertical-timeline-stack pb-10 space-y-8 md:space-y-0" data-vertical-timeline>
    {careerReverseChronological.map((entry, i) => {
      const primary = careerEntryPrimaryDomain(entry);
      const color = pickCareerDomainColor(CAREER_DOMAIN_HEX, primary);
      const yearLabels = careerYearStartEndLabels(entry);
      const locationOnly = careerStr(entry.location);
      const preview = careerHighlightsPreview(entry.highlights);
      const cardLabel = careerStr(entry.company) ?? careerStr(entry.title) ?? entry.id;
      const hasKeyMetric = Boolean(careerStr(entry.keyMetric));
      const hasTitle = Boolean(careerStr(entry.title));
      const hasHeading = hasKeyMetric || hasTitle;
      return (
      <div
        class="vertical-timeline-step relative pointer-events-none"
        data-career-entry
        data-career-domains={careerDomainsCsv(entry)}
        data-step-index={String(i)}
        data-card-side={i % 2 === 0 ? "left" : "right"}
        data-domain={primary ?? ""}
        style={`z-index: ${i + 1}; animation: ${i % 2 === 0 ? 'slideInLeft' : 'slideInRight'} 0.6s var(--ease-out-expo) ${0.15 * i}s both;`}
      >
        <div class={`relative flex items-start gap-6 md:gap-0 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
          <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] pointer-events-auto ${i % 2 === 0 ? 'md:pr-8 md:text-right' : 'md:pl-8'}`}>
            <div class="timeline-card-surface bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-accent)] transition-colors">
              {careerStr(entry.keyMetric) && (
                <p class="vertical-timeline-anchor text-lg font-bold leading-snug" style={`color: ${color};`}>
                  {entry.keyMetric}
                </p>
              )}
              {hasTitle && (
              <h3
                class:list={[
                  "vertical-timeline-title text-sm font-bold leading-snug text-[var(--color-text-secondary)]",
                  hasKeyMetric ? "mt-2" : "vertical-timeline-anchor",
                ]}
              >
                {entry.title}
              </h3>
              )}
              {(careerStr(entry.company) || locationOnly) && (
              <p
                class:list={[
                  "text-sm text-[var(--color-text-secondary)]",
                  hasHeading ? "mt-1" : "",
                  i % 2 === 0 ? "md:text-right" : "",
                ]}
              >
                {careerStr(entry.company) && (
                  <><CareerCompanyLine as="span" company={entry.company} companyUrl={entry.companyUrl} textClass="" />{locationOnly && ","}{locationOnly && <span class="text-xs text-[var(--color-text-secondary)]">{" "}{locationOnly}</span>}</>
                )}
                {!careerStr(entry.company) && locationOnly}
              </p>
              )}
              {preview.length > 0 && (
              <ul class="mt-3 space-y-2.5" data-career-highlights-list>
                {preview.map((h) => (
                  <li
                    class:list={[
                      "flex flex-row items-stretch gap-2.5 text-xs text-[var(--color-text-secondary)]",
                      i % 2 === 0 ? "justify-start md:justify-end" : "justify-start",
                    ]}
                    data-career-highlight
                    data-highlight-tags={careerHighlightTagsCsv(h.domains)}
                  >
                    <span
                      class:list={[
                        "career-hl-rail w-0.5 shrink-0 rounded-full self-stretch min-h-[1em] opacity-[0.5]",
                        i % 2 === 0 ? "order-1 md:order-2" : "order-1",
                      ]}
                      style={`background-color: ${color}`}
                      aria-hidden="true"
                    />
                    <span
                      class:list={[
                        "career-hl-text min-w-0 flex-1 text-left",
                        i % 2 === 0 ? "order-2 md:order-1 md:text-right" : "order-2",
                      ]}
                    >
                      {careerHighlightDisplayText(h.text)}
                    </span>
                  </li>
                ))}
              </ul>
              )}
              <CareerCardThumbnails
                images={entry.images}
                label={cardLabel}
                align={i % 2 === 0 ? "end" : "start"}
              />
            </div>
          </div>
        </div>

        <div
          class="vertical-timeline-dot absolute left-6 md:left-1/2 w-4 h-4 rounded-full border-2 border-[var(--color-card-bg)] z-20 shadow-sm pointer-events-none"
          style={`background-color: ${color};`}
        >
        </div>

        {yearLabels.start && (
          <div
            class="vertical-timeline-year-start absolute z-[15] pointer-events-none whitespace-nowrap text-center text-[10px] font-semibold leading-none tracking-wide text-[var(--color-text-secondary)] tabular-nums"
          >
            {yearLabels.start}
          </div>
        )}
        {yearLabels.end && (
          <div
            class="vertical-timeline-year-end absolute z-[15] pointer-events-none whitespace-nowrap text-center text-[10px] font-semibold leading-none tracking-wide text-[var(--color-text-secondary)] tabular-nums"
          >
            {yearLabels.end}
          </div>
        )}

        <div
          class="vertical-timeline-connector absolute z-10 h-[3px] md:h-2 rounded-full pointer-events-none opacity-95"
          data-card-side={i % 2 === 0 ? 'left' : 'right'}
          style={`background-color: ${color};`}
          aria-hidden="true"
        >
        </div>

        <span class="vertical-timeline-connector-tip absolute z-10 pointer-events-none block w-0 h-0 border-transparent" aria-hidden="true"></span>
      </div>
      );
    })}
  </div>
</div>

<script>
  const VERTICAL_TIMELINE_START_RATIO = 0.75;

  const DOMAIN_COLORS: Record<string, string> = {
    engineering: "#6366f1",
    startup: "#f59e0b",
    operations: "#10b981",
    product: "#3b82f6",
    b2b: "#0d9488",
    b2c: "#f43f5e",
    ai: "#e88c4f",
  };

  const MD_UP = "(min-width: 768px)";
  /** Vertical gap so start year clears the horizontal connector (right column: 3px tighter). */
  const YEAR_ABOVE_GAP_LEFT_PX = 9;
  const YEAR_ABOVE_GAP_RIGHT_PX = 9;
  const YEAR_BELOW_GAP_PX = 8;
  /** Shift year labels off the vertical spine, toward the card. */
  const YEAR_OFF_SPINE_LEFT_PX = 32;
  const YEAR_OFF_SPINE_RIGHT_PX = 20;
  const YEAR_OFF_SPINE_MOBILE_PX = 20;

  function visibleVerticalSteps(stack: HTMLElement): HTMLElement[] {
    return Array.from(stack.querySelectorAll(".vertical-timeline-step")).filter(
      (el): el is HTMLElement => el instanceof HTMLElement && !el.classList.contains("hidden"),
    );
  }

  function applyVerticalTimelineOverlap() {
    const stack = document.querySelector("[data-vertical-timeline]");
    if (!(stack instanceof HTMLElement)) return;

    stack.querySelectorAll(".vertical-timeline-step").forEach((step) => {
      if (step instanceof HTMLElement) step.style.marginTop = "";
    });

    const steps = visibleVerticalSteps(stack);
    const desktop = window.matchMedia(MD_UP).matches;

    if (!desktop) return;

    steps.forEach((step, i) => {
      if (i === 0) return;
      const prev = steps[i - 1];
      if (!prev) return;
      const h = prev.offsetHeight;
      const pullUp = (1 - VERTICAL_TIMELINE_START_RATIO) * h;
      step.style.marginTop = h > 0 ? `${-pullUp}px` : "";
    });
  }

  function alignDotsAndConnectors() {
    const stack = document.querySelector("[data-vertical-timeline]");
    if (!(stack instanceof HTMLElement)) return;

    const desktop = window.matchMedia(MD_UP).matches;
    const steps = visibleVerticalSteps(stack);

    steps.forEach((step) => {
      if (!(step instanceof HTMLElement)) return;
      const dot = step.querySelector(".vertical-timeline-dot");
      const connector = step.querySelector(".vertical-timeline-connector");
      const tip = step.querySelector(".vertical-timeline-connector-tip");
      const card = step.querySelector(".timeline-card-surface");
      const anchorEl =
        (step.querySelector(".vertical-timeline-anchor") as HTMLElement | null) ??
        (step.querySelector(".vertical-timeline-title") as HTMLElement | null) ??
        (card instanceof HTMLElement ? (card.querySelector("h3, p, span") as HTMLElement | null) : null) ??
        (card instanceof HTMLElement ? card : null);
      if (!(anchorEl instanceof HTMLElement) || !(dot instanceof HTMLElement) || !(connector instanceof HTMLElement) || !(tip instanceof HTMLElement) || !(card instanceof HTMLElement)) {
        return;
      }

      const domain = step.dataset.domain ?? "";
      const color = DOMAIN_COLORS[domain] ?? "#888";

      const stepRect = step.getBoundingClientRect();
      const anchorRect = anchorEl.getBoundingClientRect();
      const anchorCenterY = anchorRect.top - stepRect.top + anchorRect.height / 2;

      dot.style.top = `${anchorCenterY}px`;
      dot.style.transform = desktop ? "translate(-50%, -50%)" : "translate(0, -50%)";

      const dotCenterX = dot.offsetLeft + dot.offsetWidth / 2;
      const cardSide = step.dataset.cardSide ?? connector.getAttribute("data-card-side") ?? "left";
      const towardCardPx = desktop
        ? cardSide === "left"
          ? -YEAR_OFF_SPINE_LEFT_PX
          : YEAR_OFF_SPINE_RIGHT_PX
        : YEAR_OFF_SPINE_MOBILE_PX;
      const yearAnchorX = dotCenterX + towardCardPx;

      const yearAboveGapPx =
        desktop && cardSide === "right" ? YEAR_ABOVE_GAP_RIGHT_PX : YEAR_ABOVE_GAP_LEFT_PX;

      const yearStartEl = step.querySelector(".vertical-timeline-year-start");
      if (yearStartEl instanceof HTMLElement) {
        yearStartEl.style.left = `${yearAnchorX}px`;
        yearStartEl.style.top = `${anchorCenterY - yearAboveGapPx}px`;
        yearStartEl.style.transform = "translate(-50%, -100%)";
      }
      const yearEndEl = step.querySelector(".vertical-timeline-year-end");
      if (yearEndEl instanceof HTMLElement) {
        yearEndEl.style.left = `${yearAnchorX}px`;
        yearEndEl.style.top = `${anchorCenterY + YEAR_BELOW_GAP_PX}px`;
        yearEndEl.style.transform = "translate(-50%, 0)";
      }

      if (!desktop) {
        connector.style.display = "none";
        tip.style.display = "none";
        return;
      }

      const dotRect = dot.getBoundingClientRect();
      const cardRect = card.getBoundingClientRect();
      const dotCx = dotRect.left + dotRect.width / 2;
      const dotCy = dotRect.top + dotRect.height / 2;
      const dotCenterYStep = dotCy - stepRect.top;
      const side = connector.getAttribute("data-card-side") ?? "left";
      const toward = side === "left" ? -1 : 1;
      const cardEdgeX = side === "left" ? cardRect.left : cardRect.right;
      /* Connector length: 25% of prior “halfway to card” segment (= 12.5% of dot→card gap) */
      const halfLen = Math.abs(cardEdgeX - dotCx) * 0.1;
      const endX = dotCx + toward * halfLen;

      const x1 = Math.min(dotCx, endX) - stepRect.left;
      const w = Math.abs(endX - dotCx);

      if (w < 2) {
        connector.style.display = "none";
        tip.style.display = "none";
        return;
      }
      connector.style.display = "block";
      tip.style.display = "block";
      connector.style.backgroundColor = color;
      connector.style.left = `${x1}px`;
      connector.style.width = `${w}px`;
      connector.style.top = `${dotCenterYStep}px`;
      connector.style.transform = "translateY(-50%)";

      const tipHalf = 4;
      const tipW = 5;
      tip.style.borderStyle = "solid";
      tip.style.borderColor = "transparent";
      tip.style.top = `${dotCenterYStep}px`;
      tip.style.transform = "translateY(-50%)";
      if (side === "left") {
        tip.style.left = `${x1 - tipW}px`;
        tip.style.borderWidth = `${tipHalf}px ${tipW}px ${tipHalf}px 0`;
        tip.style.borderRightColor = color;
      } else {
        tip.style.left = `${x1 + w}px`;
        tip.style.borderWidth = `${tipHalf}px 0 ${tipHalf}px ${tipW}px`;
        tip.style.borderLeftColor = color;
      }
    });
  }

  function runLayout() {
    applyVerticalTimelineOverlap();
    requestAnimationFrame(() => {
      alignDotsAndConnectors();
    });
  }

  function scheduleLayout() {
    requestAnimationFrame(() => {
      requestAnimationFrame(runLayout);
    });
  }

  scheduleLayout();
  void document.fonts?.ready?.then(scheduleLayout);
  document.addEventListener("astro:page-load", scheduleLayout);

  const stackEl = document.querySelector("[data-vertical-timeline]");
  if (stackEl instanceof HTMLElement) {
    const ro = new ResizeObserver(scheduleLayout);
    ro.observe(stackEl);
    stackEl.querySelectorAll(".vertical-timeline-step").forEach((el) => ro.observe(el));
    window.addEventListener("resize", scheduleLayout);
    window.matchMedia(MD_UP).addEventListener("change", scheduleLayout);
  }

  document.addEventListener("journey-career-filter-changed", scheduleLayout);
</script>
