---
import { impactMetrics } from "@/data/portfolio";
---

<!-- Impact Option A: "Metric Cards" - Clean, scannable cards in a row -->
<section id="impact" class="mt-12 md:mt-16 py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-10 text-center">Impact at Scale</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      {impactMetrics.map((metric, i) => (
        <div
          class="group bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-5 text-center hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
          style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.1 * i}s both;`}
        >
          <span class="block text-3xl md:text-4xl font-bold text-[var(--color-accent)] mb-1">{metric.value}</span>
          <span class="block text-sm font-medium mb-2">{metric.label}</span>
          <span class="block text-xs text-[var(--color-text-secondary)]">{metric.context}</span>
          <span class="block text-[10px] text-[var(--color-text-secondary)] mt-1 opacity-0 group-hover:opacity-100 transition-opacity">{metric.company}</span>
        </div>
      ))}
    </div>
  </div>
</section>
