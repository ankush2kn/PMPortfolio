---
import { impactMetrics } from "@/data/portfolio";
---

<!-- Impact Option B: "Ticker Strip" - Horizontally scrolling news ticker -->
<section id="impact" class="mt-12 md:mt-16 overflow-hidden border-b border-[var(--color-border)]">
  <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] pt-6 md:pt-8 pb-4 md:pb-5 text-center px-6">
    Key Impact Metrics
  </h2>
  <div class="border-t border-[var(--color-border)] py-6 md:py-8">
    <div class="ticker-container relative overflow-hidden">
      <div
        class="impact-ticker-track flex w-max flex-row gap-8 md:gap-10 will-change-transform"
        data-impact-ticker-track
      >
        <div class="flex shrink-0 flex-row gap-8 md:gap-10" data-ticker-loop>
          {
            impactMetrics.map((metric) => (
              <div class="ticker-item flex items-center gap-3 pl-0 pr-1 shrink-0 cursor-default group">
                <span class="text-2xl md:text-3xl font-bold text-[var(--color-accent)] shrink-0 tabular-nums">
                  {metric.value}
                </span>
                <div class="flex flex-col max-w-[11rem] md:max-w-[13rem] text-left">
                  <span class="text-sm font-medium whitespace-normal">{metric.label}</span>
                  <span class="text-xs text-[var(--color-text-secondary)] whitespace-normal leading-snug line-clamp-2 break-words">
                    {metric.context}
                  </span>
                </div>
                <span class="text-[var(--color-border)] ml-2">|</span>
              </div>
            ))
          }
        </div>
        <div class="flex shrink-0 flex-row gap-8 md:gap-10" data-ticker-loop aria-hidden="true">
          {
            impactMetrics.map((metric) => (
              <div class="ticker-item flex items-center gap-3 pl-0 pr-1 shrink-0 cursor-default group">
                <span class="text-2xl md:text-3xl font-bold text-[var(--color-accent)] shrink-0 tabular-nums">
                  {metric.value}
                </span>
                <div class="flex flex-col max-w-[11rem] md:max-w-[13rem] text-left">
                  <span class="text-sm font-medium whitespace-normal">{metric.label}</span>
                  <span class="text-xs text-[var(--color-text-secondary)] whitespace-normal leading-snug line-clamp-2 break-words">
                    {metric.context}
                  </span>
                </div>
                <span class="text-[var(--color-border)] ml-2">|</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes impact-ticker-marquee {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(calc(-1 * var(--ticker-period-px, 0px)), 0, 0);
    }
  }

  .impact-ticker-track {
    --impact-ticker-duration: 14s;
    backface-visibility: hidden;
    opacity: 0;
  }

  .impact-ticker-track.ticker-ready {
    opacity: 1;
    animation-name: impact-ticker-marquee;
    animation-duration: var(--impact-ticker-duration);
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-delay: 1s;
  }

  @media (min-width: 768px) {
    .impact-ticker-track {
      --impact-ticker-duration: 22s;
    }
  }

  @media (min-width: 1024px) {
    .impact-ticker-track {
      --impact-ticker-duration: 30s;
    }
  }

  .ticker-container:hover .impact-ticker-track.ticker-ready {
    animation-play-state: paused;
  }
</style>

<script>
  function initImpactTickerMarquee() {
    const track = document.querySelector("[data-impact-ticker-track]");
    if (!(track instanceof HTMLElement)) return;

    const loops = track.querySelectorAll("[data-ticker-loop]");
    if (loops.length < 2) return;

    const apply = () => {
      const a = loops[0].getBoundingClientRect();
      const b = loops[1].getBoundingClientRect();
      const period = b.left - a.left;
      if (!Number.isFinite(period) || period < 2) return;
      track.style.setProperty("--ticker-period-px", `${period}px`);
      track.classList.add("ticker-ready");
    };

    const schedule = () => requestAnimationFrame(() => requestAnimationFrame(apply));

    schedule();
    void document.fonts?.ready?.then(schedule);

    const ro = new ResizeObserver(schedule);
    ro.observe(track);
    loops.forEach((el) => ro.observe(el));
    window.addEventListener("resize", schedule);
  }

  initImpactTickerMarquee();
  document.addEventListener("astro:page-load", initImpactTickerMarquee);
</script>
