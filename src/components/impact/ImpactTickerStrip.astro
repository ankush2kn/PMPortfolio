---
import { impactMetrics } from "@/data/portfolio";
const doubled = [...impactMetrics, ...impactMetrics];
---

<!-- Impact Option B: "Ticker Strip" - Horizontally scrolling news ticker -->
<section id="impact" class="mt-12 md:mt-16 py-6 md:py-8 overflow-hidden border-y border-[var(--color-border)]">
  <div class="ticker-container relative">
    <div class="ticker-track flex gap-12 whitespace-nowrap" style="animation: ticker-scroll 30s linear infinite;">
      {doubled.map((metric) => (
        <div class="ticker-item flex items-center gap-3 px-4 shrink-0 cursor-default group">
          <span class="text-2xl md:text-3xl font-bold text-[var(--color-accent)]">{metric.value}</span>
          <div class="flex flex-col">
            <span class="text-sm font-medium">{metric.label}</span>
            <span class="text-xs text-[var(--color-text-secondary)]">{metric.context}</span>
          </div>
          <span class="text-[var(--color-border)] mx-2">|</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ticker-container:hover .ticker-track {
    animation-play-state: paused;
  }
</style>
