---
interface Props {
  animated?: boolean;
  class?: string;
}
const { animated = true, class: className = "" } = Astro.props;
---

<!-- Option C: "Line-Art Avatar" - Continuous line drawing self-portrait that draws itself -->
<div class={`inline-block ${className}`} data-character="lineart">
  <svg viewBox="0 0 200 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" style="max-width: 200px;">
    <path
      class:list={["line-art-path", { animated }]}
      d="M80 50 
         Q75 35 85 25 Q95 18 105 20 Q115 18 125 25 Q135 35 130 50
         Q140 55 142 70 Q144 85 140 100 Q135 115 125 120
         L120 125 L120 130 Q130 135 140 145 L145 155 L160 185 L155 190 L145 180 L140 190
         L140 235 L135 310 L130 322 L110 322 L115 310 L120 240
         L105 240
         L90 310 L85 322 L65 322 L70 310 L75 235
         L75 190 L65 180 L55 190 L50 185 L65 155 L70 145 Q80 135 90 130 L90 125 L85 120
         Q75 115 68 100 Q64 85 68 70 Q70 55 80 50 Z"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <!-- Facial features (separate paths so they draw after the body) -->
    <g class:list={["line-art-features", { animated }]}>
      <!-- Left eye -->
      <ellipse cx="92" cy="75" rx="5" ry="3.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <circle cx="92" cy="75" r="1.5" fill="currentColor"/>

      <!-- Right eye -->
      <ellipse cx="118" cy="75" rx="5" ry="3.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <circle cx="118" cy="75" r="1.5" fill="currentColor"/>

      <!-- Nose -->
      <path d="M105 80 L102 92 L108 92" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>

      <!-- Smile -->
      <path d="M94 100 Q105 110 116 100" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>

      <!-- Shirt collar hint -->
      <path d="M90 130 L105 145 L120 130" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
    </g>
  </svg>
</div>

<style>
  .line-art-path.animated {
    stroke-dasharray: 1800;
    stroke-dashoffset: 1800;
    animation: draw-line 3s ease-out forwards;
  }

  .line-art-features.animated {
    opacity: 0;
    animation: fadeIn 0.8s ease-out 2.5s forwards;
  }

  @keyframes draw-line {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
