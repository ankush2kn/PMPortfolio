---
import { skillCredentialHref, skillCredentialLabel, skills } from "@/data/portfolio";

const categories = [
  { label: "AI / ML", tools: skills.tools.filter(t => t.category === "AI/ML") },
  { label: "Cloud & Infra", tools: skills.tools.filter(t => t.category === "Cloud") },
  { label: "Analytics", tools: skills.tools.filter(t => t.category === "Analytics") },
  { label: "Growth & Ops", tools: skills.tools.filter(t => t.category === "Growth") },
];

const credentialsRow1 = skills.credentials.slice(0, 2);
const credentialsRow2 = skills.credentials.slice(2);
---

<!-- Skills Option C: "Tool Shelf" - Visual shelf with tool icons grouped by category -->
<section class="pt-10 pb-20 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-6 text-center">Tech Credentials</h2>

    <div class="mb-10 flex flex-col items-center gap-3" style="animation: fadeInUp 0.6s var(--ease-out-expo) both;">
      <div class="flex flex-wrap justify-center gap-3">
        {credentialsRow1.map((cred) => {
          const label = skillCredentialLabel(cred);
          const href = skillCredentialHref(cred);
          const base = "flex items-center gap-2 px-3 py-1.5 bg-[var(--color-accent)]/10 rounded-full";
          const linkExtra =
            "hover:bg-[var(--color-accent)]/18 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]";
          const inner = (
            <>
              <svg class="w-3.5 h-3.5 text-[var(--color-accent)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-xs font-medium text-[var(--color-accent)]">{label}</span>
            </>
          );
          return href ? (
            <a href={href} target="_blank" rel="noopener noreferrer" class:list={[base, linkExtra]}>
              {inner}
              <span class="sr-only">Opens in new tab</span>
            </a>
          ) : (
            <div class={base}>{inner}</div>
          );
        })}
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {credentialsRow2.map((cred) => {
          const label = skillCredentialLabel(cred);
          const href = skillCredentialHref(cred);
          const base = "flex items-center gap-2 px-3 py-1.5 bg-[var(--color-accent)]/10 rounded-full";
          const linkExtra =
            "hover:bg-[var(--color-accent)]/18 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]";
          const inner = (
            <>
              <svg class="w-3.5 h-3.5 text-[var(--color-accent)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-xs font-medium text-[var(--color-accent)]">{label}</span>
            </>
          );
          return href ? (
            <a href={href} target="_blank" rel="noopener noreferrer" class:list={[base, linkExtra]}>
              {inner}
              <span class="sr-only">Opens in new tab</span>
            </a>
          ) : (
            <div class={base}>{inner}</div>
          );
        })}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {categories.map((cat, ci) => (
        <div
          class="bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-5"
          style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.1 * ci}s both;`}
        >
          <h3 class="text-xs uppercase tracking-wider text-[var(--color-accent)] mb-4 font-semibold">{cat.label}</h3>
          <div class="grid grid-cols-2 gap-2">
            {cat.tools.map((tool) => (
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-[var(--color-bg-secondary)] transition-colors group">
                <div class="w-6 h-6 rounded bg-[var(--color-accent)]/10 flex items-center justify-center shrink-0">
                  <span class="text-[10px] font-bold text-[var(--color-accent)]">{tool.name.substring(0, 2).toUpperCase()}</span>
                </div>
                <span class="text-sm truncate">{tool.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
