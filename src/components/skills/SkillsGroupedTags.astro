---
import { skillCredentialHref, skillCredentialLabel, skills } from "@/data/portfolio";

const groups = [
  { label: "Product", items: skills.product },
  { label: "Technical", items: skills.technical },
  { label: "Domain", items: skills.domain },
];
---

<!-- Skills Option A: "Grouped Tags" - Skills as tag chips organized by category -->
<section class="pt-10 pb-20 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-4 text-center">Skills & Expertise</h2>

    <div class="mb-10" style="animation: fadeInUp 0.6s var(--ease-out-expo) both;">
      <h3 class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold text-center mb-4">Tech Credentials</h3>
      <div class="flex flex-wrap justify-center gap-2">
        {skills.credentials.map((cred) => {
          const label = skillCredentialLabel(cred);
          const href = skillCredentialHref(cred);
          const base =
            "px-3 py-1.5 text-sm bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full font-medium";
          const linkExtra =
            "hover:bg-[var(--color-accent)]/18 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]";
          return href ? (
            <a href={href} target="_blank" rel="noopener noreferrer" class:list={[base, linkExtra]}>
              {label}
              <span class="sr-only">Opens in new tab</span>
            </a>
          ) : (
            <span class={base}>{label}</span>
          );
        })}
      </div>
    </div>

    <div class="space-y-8">
      {groups.map((group, gi) => (
        <div style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.15 * gi}s both;`}>
          <h3 class="text-xs uppercase tracking-wider text-[var(--color-text-secondary)] mb-3 font-medium">{group.label}</h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <span class="px-3 py-1.5 text-sm border border-[var(--color-border)] rounded-full hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
