---
import { projects } from "@/data/portfolio";

const CHALLENGE_LABEL = "Why it existed";
const OUTCOME_LABEL = "What I shipped";
---

<!-- Projects Option A: App-style cards with screenshot + challenge / outcome -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  {projects.map((project, i) => (
    <a
      href={project.url}
      target="_blank"
      rel="noopener"
      class="group bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-2xl p-5 hover:border-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1 hover:shadow-lg block"
      style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.15 * i}s both;`}
    >
      <div class="flex gap-4 mb-4">
        <div class="w-[4.5rem] h-[4.5rem] shrink-0 rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
          <img
            src={project.screenshot}
            alt={`${project.name} site preview`}
            class="w-full h-full object-cover object-top"
            width="72"
            height="72"
            loading="lazy"
          />
        </div>
        <div class="min-w-0 flex-1 pt-0.5">
          <h3 class="text-lg font-bold leading-tight group-hover:text-[var(--color-accent)] transition-colors">{project.name}</h3>
          <p class="text-xs text-[var(--color-text-secondary)] mt-1 line-clamp-2">{project.tagline}</p>
        </div>
      </div>

      <div class="space-y-2 mb-4 text-left">
        <div>
          <p class="text-[10px] uppercase tracking-wider font-semibold text-[var(--color-accent)] mb-0.5">{CHALLENGE_LABEL}</p>
          <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">{project.challenge}</p>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-wider font-semibold text-[var(--color-accent)] mb-0.5">{OUTCOME_LABEL}</p>
          <p class="text-xs text-[var(--color-text)] leading-relaxed">{project.outcome}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-1.5 mb-3">
        {project.metrics.map((m) => (
          <span class="text-[10px] px-2 py-0.5 bg-[var(--color-bg-secondary)] rounded-full text-[var(--color-text-secondary)]">{m}</span>
        ))}
      </div>

      <div class="flex flex-wrap gap-1">
        {project.techStack.map((t) => (
          <span class="text-[10px] px-1.5 py-0.5 border border-[var(--color-border)] rounded text-[var(--color-text-secondary)]">{t}</span>
        ))}
      </div>

      <div class="mt-4 text-xs text-[var(--color-accent)] font-medium group-hover:underline">
        View Project →
      </div>
    </a>
  ))}
</div>
