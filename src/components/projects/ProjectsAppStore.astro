---
import { projects } from "@/data/portfolio";
import AppStoreProjectCard from "@/components/projects/AppStoreProjectCard.astro";
---

<!-- Projects Option A: App-style cards with screenshot + challenge / outcome -->
<div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:items-stretch">
  {projects.map((project, i) => (
    <AppStoreProjectCard project={project} i={i} />
  ))}
</div>
