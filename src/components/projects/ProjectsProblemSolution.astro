---
import type { PortfolioProject } from "@/data/portfolio";
import { projects } from "@/data/portfolio";
---

<!-- Projects Option C: "Problem/Solution" - Two-panel micro-cards -->
<div class="space-y-6">
  {projects.map((project: PortfolioProject, i) => {
    const productUrl = project.url?.trim();
    const techStack = project.techStack ?? [];
    const anim = `animation: fadeInUp 0.6s var(--ease-out-expo) ${0.15 * i}s both;`;
    const shellClass =
      "group block bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl overflow-hidden hover:border-[var(--color-accent)] transition-all duration-300";

    const inner = (
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="p-5 md:border-r border-[var(--color-border)]">
          <span class="text-[10px] uppercase tracking-wider text-[var(--color-text-secondary)] font-medium">Problem</span>
          <p class="text-sm mt-2 text-[var(--color-text-secondary)]">{project.challenge}</p>
        </div>
        <div class="p-5 bg-[var(--color-accent)]/5">
          <div class="flex items-start justify-between">
            <span class="text-[10px] uppercase tracking-wider text-[var(--color-accent)] font-medium">Solution: {project.name}</span>
            {productUrl && (
              <svg class="w-4 h-4 text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
              </svg>
            )}
          </div>
          <p class="text-sm mt-2">{project.outcome}</p>
          <p class="text-xs mt-2 text-[var(--color-text-secondary)] leading-relaxed">{project.description}</p>
          {techStack.length > 0 && (
            <div class="flex flex-wrap gap-1 mt-3">
              {techStack.map((t) => (
                <span class="text-[9px] px-1.5 py-0.5 border border-[var(--color-accent)]/30 rounded text-[var(--color-accent)]">{t}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    );

    return productUrl ? (
      <a href={productUrl} target="_blank" rel="noopener" class:list={[shellClass]} style={anim}>
        {inner}
      </a>
    ) : (
      <div class:list={[shellClass, "cursor-default"]} style={anim}>
        {inner}
      </div>
    );
  })}
</div>
