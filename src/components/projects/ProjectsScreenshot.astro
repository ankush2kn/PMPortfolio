---
import { projects } from "@/data/portfolio";
---

<!-- Projects Option B: "Screenshot + Overlay" - Device frames with hover overlays -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
  {projects.map((project, i) => (
    <a
      href={project.url}
      target="_blank"
      rel="noopener"
      class="group block"
      style={`animation: fadeInUp 0.6s var(--ease-out-expo) ${0.15 * i}s both;`}
    >
      <!-- Device frame (laptop mockup) -->
      <div class="relative rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-card-bg)]">
        <!-- Browser chrome -->
        <div class="flex items-center gap-1.5 px-3 py-2 bg-[var(--color-bg-secondary)] border-b border-[var(--color-border)]">
          <div class="w-2 h-2 rounded-full bg-red-400/60"></div>
          <div class="w-2 h-2 rounded-full bg-yellow-400/60"></div>
          <div class="w-2 h-2 rounded-full bg-green-400/60"></div>
          <div class="ml-2 flex-1 bg-[var(--color-bg)] rounded px-2 py-0.5 text-[9px] text-[var(--color-text-secondary)] truncate">
            {project.url}
          </div>
        </div>

        <!-- Screenshot placeholder (gradient + icon) -->
        <div class="aspect-[16/10] bg-gradient-to-br from-[var(--color-bg-secondary)] to-[var(--color-bg)] flex items-center justify-center relative">
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center mx-auto mb-3">
              <span class="text-2xl font-bold text-[var(--color-accent)]">{project.name.charAt(0)}</span>
            </div>
            <span class="text-sm text-[var(--color-text-secondary)]">{project.name}</span>
          </div>

          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-[var(--color-text)]/85 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="text-center text-white px-6">
              <h3 class="text-lg font-bold mb-2">{project.name}</h3>
              <p class="text-sm opacity-80 mb-3">{project.tagline}</p>
              <div class="flex flex-wrap justify-center gap-1.5 mb-3">
                {project.techStack.map((t) => (
                  <span class="text-[10px] px-2 py-0.5 border border-white/30 rounded-full">{t}</span>
                ))}
              </div>
              <span class="text-xs text-[var(--color-accent)] font-medium">View Live →</span>
            </div>
          </div>
        </div>
      </div>

      <h3 class="text-sm font-semibold mt-3 group-hover:text-[var(--color-accent)] transition-colors">{project.name}</h3>
      <p class="text-xs text-[var(--color-text-secondary)]">{project.tagline}</p>
    </a>
  ))}
</div>
