---
import { caseStudies } from "@/data/portfolio";

const study = caseStudies[0];
---

{study && (
  <section class="pt-20 pb-10 px-6" aria-labelledby="featured-case-study-heading">
    <div class="max-w-3xl mx-auto">
      <div class="bg-[var(--color-card-bg)] border border-[var(--color-accent)]/30 rounded-xl overflow-hidden">
        <button
          type="button"
          class="w-full p-5 text-left flex items-center justify-between group"
          id="featured-case-study-toggle"
          aria-expanded="false"
          aria-controls="featured-case-study-details"
        >
          <div>
            <div class="flex items-center gap-3 mb-1">
              <span class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-medium">{study.label}</span>
              <span class="text-xs text-[var(--color-text-secondary)]">{study.company} &middot; {study.period}</span>
            </div>
            <h3 id="featured-case-study-heading" class="text-lg font-bold">{study.title}</h3>
            <p class="text-2xl font-bold text-[var(--color-accent)] mt-1">{study.keyMetric}</p>
          </div>
          <svg
            class="w-5 h-5 text-[var(--color-text-secondary)] transition-transform group-hover:text-[var(--color-accent)] shrink-0"
            id="featured-case-study-chevron"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </button>
        <div class="hidden px-5 pb-5 border-t border-[var(--color-border)]" id="featured-case-study-details">
          <ul class="mt-4 space-y-2 text-sm text-[var(--color-text-secondary)]">
            {study.bullets.map((bullet) => (
              <li class="flex items-start gap-2">
                <span class="text-[var(--color-accent)] mt-0.5">&#8226;</span>
                {bullet}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  const toggle = document.getElementById("featured-case-study-toggle");
  const details = document.getElementById("featured-case-study-details");
  const chevron = document.getElementById("featured-case-study-chevron");

  toggle?.addEventListener("click", () => {
    const isHidden = details?.classList.contains("hidden");
    details?.classList.toggle("hidden");
    toggle?.setAttribute("aria-expanded", isHidden ? "true" : "false");
    chevron?.style.setProperty("transform", isHidden ? "rotate(180deg)" : "rotate(0)");
  });
</script>
