---
import { profile } from "@/data/portfolio";
---

<!-- Contact Option B: "The Terminal" - Mock command line interface -->
<section class="py-20 px-6 border-t border-[var(--color-border)]">
  <div class="max-w-xl mx-auto">
    <div class="bg-[#0d0d0d] rounded-xl overflow-hidden border border-[#333] shadow-2xl">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-3 bg-[#1a1a1a] border-b border-[#333]">
        <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
        <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
      </div>
      <!-- Terminal body -->
      <div class="p-5 font-mono text-sm space-y-3 text-[#e0e0e0]">
        <div>
          <span class="text-[var(--color-accent)]">$</span> <span class="text-[#888]">ankush</span>.status
          <div class="mt-1 ml-4 text-[#4ade80]">&#10003; Available immediately</div>
        </div>
        <div>
          <span class="text-[var(--color-accent)]">$</span> <span class="text-[#888]">ankush</span>.seeking
          <div class="mt-1 ml-4 text-[#ccc] space-y-1">
            <div>
              <span class="text-[#666] select-none mr-2">&gt;</span>{profile.seeking}
            </div>
            <div>
              <span class="text-[#666] select-none mr-2">&gt;</span>{profile.seekingSubline}
            </div>
          </div>
        </div>
        <div>
          <span class="text-[var(--color-accent)]">$</span> <span class="text-[#888]">ankush</span>.connect
          <div class="mt-1 ml-4 space-y-1">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-[#888]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22 0H2C.9 0 0 .9 0 2v20c0 1.1.9 2 2 2h20c1.1 0 2-.9 2-2V2c0-1.1-.9-2-2-2z"
                />
              </svg>
              <span>
                <a href={profile.linkedin} target="_blank" rel="noopener me" class="text-[var(--color-accent)] hover:underline">[linkedin]</a>
                <span class="text-[#666]"> /ankushbhargava</span>
              </span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-[#888]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
              <span>
                <a href={profile.twitter} target="_blank" rel="noopener me" class="text-[var(--color-accent)] hover:underline">[x]</a>
                <span class="text-[#666]"> @TheKushBhargava</span>
              </span>
            </div>
            <div class="flex items-center gap-2">
              <img
                src="/images/ProductLogistics_Logo_v2.png"
                alt=""
                class="h-4 w-4 shrink-0 object-contain"
                width="16"
                height="16"
                loading="lazy"
                decoding="async"
              />
              <span>
                <a href={profile.newsletter} target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline" title="The Product Logistics — my blog">[my blog]</a>
                <span class="text-[#666]"> The Product Logistics</span>
              </span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-[#888]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>
                <a href={profile.github} target="_blank" rel="noopener me" class="text-[var(--color-accent)] hover:underline">[github]</a>
                <span class="text-[#666]"> /ankush2kn</span>
              </span>
            </div>
          </div>
        </div>
        <div class="flex items-center">
          <span class="text-[var(--color-accent)]">$</span>
          <span
            class="terminal-caret ml-1 w-2 h-4 bg-[var(--color-accent)] inline-block"
            aria-hidden="true"
          ></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes terminal-caret-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
  .terminal-caret {
    animation: terminal-caret-blink 1s step-end infinite;
  }
</style>
