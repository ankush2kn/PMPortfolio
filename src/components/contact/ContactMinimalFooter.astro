---
import { profile } from "@/data/portfolio";
---

<!-- Contact Option C: "Minimal Footer" - Always visible bottom bar -->
<footer class="border-t border-[var(--color-border)] py-6 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="text-sm font-medium">{profile.name}</span>
      <span class="text-[var(--color-border)]">|</span>
      <div class="flex items-center gap-1.5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-available)] opacity-75" style="animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-available)]"></span>
        </span>
        <span class="text-xs text-[var(--color-available)]">{profile.availability}</span>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <a href={profile.linkedin} target="_blank" rel="noopener" class="text-sm hover:text-[var(--color-accent)] transition-colors">LinkedIn</a>
      <a href={profile.github} target="_blank" rel="noopener" class="text-sm hover:text-[var(--color-accent)] transition-colors">GitHub</a>
    </div>
  </div>
</footer>

<style>
  @keyframes ping {
    75%, 100% { transform: scale(2); opacity: 0; }
  }
</style>
