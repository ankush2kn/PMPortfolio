---
import { profile } from "@/data/portfolio";
---

<!-- Contact Option A: "The Open Door" - CTA without character -->
<section class="py-20 px-6 border-t border-[var(--color-border)]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-3">Let's Build Something</h2>
    <p class="text-[var(--color-text-secondary)] mb-2">{profile.seeking}</p>
    <div class="flex items-center justify-center gap-2 mb-8">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-available)] opacity-75" style="animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-available)]"></span>
      </span>
      <span class="text-sm text-[var(--color-available)]">{profile.availability}</span>
    </div>
    <div class="flex flex-wrap justify-center gap-3">
      <a href={profile.linkedin} target="_blank" rel="noopener" class="px-6 py-2.5 bg-[var(--color-accent)] text-white rounded-full text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
        Message on LinkedIn
      </a>
      <a
        href={profile.newsletter}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-6 py-2.5 border border-[var(--color-border)] rounded-full text-sm font-medium hover:bg-[var(--color-bg-secondary)] transition-colors"
        title="The Product Logistics — my blog"
      >
        <img
          src="/images/ProductLogistics_Logo_v2.png"
          alt=""
          class="h-5 w-5 shrink-0 object-contain"
          width="20"
          height="20"
          loading="lazy"
          decoding="async"
        />
        My blog
      </a>
      <a href={profile.github} target="_blank" rel="noopener" class="px-6 py-2.5 border border-[var(--color-border)] rounded-full text-sm font-medium hover:bg-[var(--color-bg-secondary)] transition-colors">
        GitHub
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes ping {
    75%, 100% { transform: scale(2); opacity: 0; }
  }
</style>
