---
import Layout from "@/layouts/Layout.astro";
import TimelineSubway from "@/components/timeline/TimelineSubway.astro";
import TimelineElevation from "@/components/timeline/TimelineElevation.astro";
import TimelineVertical from "@/components/timeline/TimelineVertical.astro";
import TimelineOrbit from "@/components/timeline/TimelineOrbit.astro";
import TimelineFilmStrip from "@/components/timeline/TimelineFilmStrip.astro";
import ContactMinimalFooter from "@/components/contact/ContactMinimalFooter.astro";
import { education } from "@/data/portfolio";
---

<Layout title="The Journey — Ankush Bhargava">
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">The Journey</h1>
        <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">
          20+ years across engineering, startups, enterprise operations, and product leadership.
          From building code to building organizations.
        </p>
      </div>

      <!-- TIMELINE VARIANTS -->
      <div data-variant-group="Timeline" data-variant="Subway">
        <TimelineSubway />
      </div>
      <div data-variant-group="Timeline" data-variant="Elevation">
        <TimelineElevation />
      </div>
      <div data-variant-group="Timeline" data-variant="Vertical">
        <TimelineVertical />
      </div>
      <div data-variant-group="Timeline" data-variant="Orbit">
        <TimelineOrbit />
      </div>
      <div data-variant-group="Timeline" data-variant="FilmStrip">
        <TimelineFilmStrip />
      </div>

      <!-- Education section -->
      <div class="mt-20 max-w-2xl mx-auto">
        <h2 class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-6 text-center">Education</h2>
        <div class="space-y-4">
          {education.map((edu) => (
            <div class="flex items-start gap-4 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-4">
              <div class="w-10 h-10 rounded-lg bg-[var(--color-accent)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-bold">{edu.degree}</h3>
                <p class="text-xs text-[var(--color-text-secondary)]">{edu.focus}</p>
                <p class="text-xs text-[var(--color-text-secondary)]">{edu.school} &middot; {edu.year}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ContactMinimalFooter />
</Layout>
