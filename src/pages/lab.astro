---
import Layout from "@/layouts/Layout.astro";
import ProjectsAppStore from "@/components/projects/ProjectsAppStore.astro";
import ProjectsScreenshot from "@/components/projects/ProjectsScreenshot.astro";
import ProjectsProblemSolution from "@/components/projects/ProjectsProblemSolution.astro";
import ContactMinimalFooter from "@/components/contact/ContactMinimalFooter.astro";
import { profile } from "@/data/portfolio";
---

<Layout title="The Lab — Ankush Bhargava">
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">The Lab</h1>
        <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">
          Post-Walmart, I established a high-velocity R&D sandbox to build with agentic workflows and GenAI.
          These aren't side projects — they're live products built end-to-end.
        </p>
      </div>

      <!-- Moderate case study example (one expandable card) -->
      <div class="mb-12 max-w-3xl mx-auto">
        <div class="bg-[var(--color-card-bg)] border border-[var(--color-accent)]/30 rounded-xl overflow-hidden">
          <button
            class="w-full p-5 text-left flex items-center justify-between group"
            id="case-study-toggle"
          >
            <div>
              <div class="flex items-center gap-3 mb-1">
                <span class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-medium">Featured Case Study</span>
                <span class="text-xs text-[var(--color-text-secondary)]">Walmart Tech &middot; 2019–2024</span>
              </div>
              <h3 class="text-lg font-bold">B2B Transportation Marketplace</h3>
              <p class="text-2xl font-bold text-[var(--color-accent)] mt-1">$250M ARR</p>
            </div>
            <svg class="w-5 h-5 text-[var(--color-text-secondary)] transition-transform group-hover:text-[var(--color-accent)]" id="case-study-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
            </svg>
          </button>
          <div class="hidden px-5 pb-5 border-t border-[var(--color-border)]" id="case-study-details">
            <ul class="mt-4 space-y-2 text-sm text-[var(--color-text-secondary)]">
              <li class="flex items-start gap-2">
                <span class="text-[var(--color-accent)] mt-0.5">&#8226;</span>
                Conceived and co-created vision with cross-functional leaders across GTM, CRM, safety, fraud, and mobile
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[var(--color-accent)] mt-0.5">&#8226;</span>
                Optimized onboarding funnel for 3,000 carriers — reduced activation from 90+ days to 1 day
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[var(--color-accent)] mt-0.5">&#8226;</span>
                Partnered with Salesforce, Quantum Metrics, Braze, JPMorgan, RMIS to accelerate launch
              </li>
              <li class="flex items-start gap-2">
                <span class="text-[var(--color-accent)] mt-0.5">&#8226;</span>
                0→1 build: from concept to $250M ARR marketplace
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- PROJECT VARIANTS -->
      <div data-variant-group="Projects" data-variant="A">
        <ProjectsAppStore />
      </div>
      <div data-variant-group="Projects" data-variant="B">
        <ProjectsScreenshot />
      </div>
      <div data-variant-group="Projects" data-variant="C">
        <ProjectsProblemSolution />
      </div>
    </div>
  </section>

  <ContactMinimalFooter />
</Layout>

<script>
  const toggle = document.getElementById('case-study-toggle');
  const details = document.getElementById('case-study-details');
  const chevron = document.getElementById('case-study-chevron');
  toggle?.addEventListener('click', () => {
    const isHidden = details?.classList.contains('hidden');
    details?.classList.toggle('hidden');
    chevron?.style.setProperty('transform', isHidden ? 'rotate(180deg)' : 'rotate(0)');
  });
</script>
