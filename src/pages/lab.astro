---
import Layout from "@/layouts/Layout.astro";
import { DEFAULT_VARIANTS } from "@/data/siteDefaults";
import ProjectsAppStore from "@/components/projects/ProjectsAppStore.astro";
import ProjectsScreenshot from "@/components/projects/ProjectsScreenshot.astro";
import ProjectsProblemSolution from "@/components/projects/ProjectsProblemSolution.astro";
import ContactMinimalFooter from "@/components/contact/ContactMinimalFooter.astro";
import { profile } from "@/data/portfolio";
function defaultAttr(group: keyof typeof DEFAULT_VARIANTS, variant: string) {
  return DEFAULT_VARIANTS[group] === variant ? ({ "data-is-default": true } as const) : {};
}
---

<Layout title="My Lab — Ankush Bhargava">
  <section class="pt-12 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">My Lab</h1>
        <p class="max-w-5xl mx-auto text-[var(--color-text-secondary)] leading-relaxed">
          Post-Walmart, I established a high-velocity R&D sandbox to build with agentic workflows and GenAI.<br />
          These are live products built end-to-end.
        </p>
      </div>

      <!-- PROJECT VARIANTS -->
      <div data-variant-group="Projects" data-variant="A" {...defaultAttr("Projects", "A")}>
        <ProjectsAppStore />
      </div>
      <div data-variant-group="Projects" data-variant="B" {...defaultAttr("Projects", "B")}>
        <ProjectsScreenshot />
      </div>
      <div data-variant-group="Projects" data-variant="C" {...defaultAttr("Projects", "C")}>
        <ProjectsProblemSolution />
      </div>

      <div
        class="mt-16 max-w-2xl mx-auto rounded-xl border border-[var(--color-border)] bg-[var(--color-card-bg)] px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
      >
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed text-center sm:text-left">
          This portfolio website is open source on GitHub — star the repo if it’s useful, or fork it for your own site.
        </p>
        <a
          href={profile.portfolioRepo}
          target="_blank"
          rel="noopener"
          class="shrink-0 inline-flex items-center justify-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-2.5 text-sm font-medium hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"
            />
          </svg>
          ankush2kn/PMPortfolio
        </a>
      </div>
    </div>
  </section>

  <ContactMinimalFooter />
</Layout>
