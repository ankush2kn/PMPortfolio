---
import Layout from "@/layouts/Layout.astro";
import { DEFAULT_VARIANTS } from "@/data/siteDefaults";
import HeroAnimatedIntro from "@/components/hero/HeroAnimatedIntro.astro";
import HeroSplitScreen from "@/components/hero/HeroSplitScreen.astro";
import HeroBusinessCard from "@/components/hero/HeroBusinessCard.astro";
import ImpactMetricCards from "@/components/impact/ImpactMetricCards.astro";
import ImpactTickerStrip from "@/components/impact/ImpactTickerStrip.astro";
import ImpactNapkinSketch from "@/components/impact/ImpactNapkinSketch.astro";
import SkillsGroupedTags from "@/components/skills/SkillsGroupedTags.astro";
import SkillsOrbitRings from "@/components/skills/SkillsOrbitRings.astro";
import SkillsToolShelf from "@/components/skills/SkillsToolShelf.astro";
import PrinciplesGrid from "@/components/principles/PrinciplesGrid.astro";
import PrinciplesMarquee from "@/components/principles/PrinciplesMarquee.astro";
import PrinciplesHandwritten from "@/components/principles/PrinciplesHandwritten.astro";
import ContactOpenDoor from "@/components/contact/ContactOpenDoor.astro";
import ContactTerminal from "@/components/contact/ContactTerminal.astro";
import ContactMinimalFooter from "@/components/contact/ContactMinimalFooter.astro";

function defaultAttr(group: keyof typeof DEFAULT_VARIANTS, variant: string) {
  return DEFAULT_VARIANTS[group] === variant ? ({ "data-is-default": true } as const) : {};
}
---

<Layout>
  <!-- HERO VARIANTS -->
  <div data-variant-group="Hero" data-variant="A" {...defaultAttr("Hero", "A")}>
    <HeroAnimatedIntro />
  </div>
  <div data-variant-group="Hero" data-variant="B" {...defaultAttr("Hero", "B")}>
    <HeroSplitScreen />
  </div>
  <div data-variant-group="Hero" data-variant="C" {...defaultAttr("Hero", "C")}>
    <HeroBusinessCard />
  </div>

  <!-- IMPACT VARIANTS -->
  <div data-variant-group="Impact" data-variant="A" {...defaultAttr("Impact", "A")}>
    <ImpactMetricCards />
  </div>
  <div data-variant-group="Impact" data-variant="B" {...defaultAttr("Impact", "B")}>
    <ImpactTickerStrip />
  </div>
  <div data-variant-group="Impact" data-variant="C" {...defaultAttr("Impact", "C")}>
    <ImpactNapkinSketch />
  </div>

  <!-- PRINCIPLES VARIANTS -->
  <div data-variant-group="Principles" data-variant="A" {...defaultAttr("Principles", "A")}>
    <PrinciplesGrid />
  </div>
  <div data-variant-group="Principles" data-variant="B" {...defaultAttr("Principles", "B")}>
    <PrinciplesMarquee />
  </div>
  <div data-variant-group="Principles" data-variant="C" {...defaultAttr("Principles", "C")}>
    <PrinciplesHandwritten />
  </div>

  <!-- SKILLS VARIANTS -->
  <div data-variant-group="Skills" data-variant="A" {...defaultAttr("Skills", "A")}>
    <SkillsGroupedTags />
  </div>
  <div data-variant-group="Skills" data-variant="B" {...defaultAttr("Skills", "B")}>
    <SkillsOrbitRings />
  </div>
  <div data-variant-group="Skills" data-variant="C" {...defaultAttr("Skills", "C")}>
    <SkillsToolShelf />
  </div>

  <!-- CONTACT VARIANTS -->
  <div data-variant-group="Contact" data-variant="A" {...defaultAttr("Contact", "A")}>
    <ContactOpenDoor />
  </div>
  <div data-variant-group="Contact" data-variant="B" {...defaultAttr("Contact", "B")}>
    <ContactTerminal />
  </div>
  <div data-variant-group="Contact" data-variant="C" {...defaultAttr("Contact", "C")}>
    <ContactMinimalFooter />
  </div>
</Layout>
