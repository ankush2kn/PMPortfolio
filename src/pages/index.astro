---
import Layout from "@/layouts/Layout.astro";
import { DEFAULT_VARIANTS } from "@/data/siteDefaults";
import HeroAnimatedIntro from "@/components/hero/HeroAnimatedIntro.astro";
import HeroSplitScreen from "@/components/hero/HeroSplitScreen.astro";
import HeroBusinessCard from "@/components/hero/HeroBusinessCard.astro";
import HeroBio from "@/components/hero/HeroBio.astro";
import ImpactMetricCards from "@/components/impact/ImpactMetricCards.astro";
import ImpactTickerStrip from "@/components/impact/ImpactTickerStrip.astro";
import ImpactNapkinSketch from "@/components/impact/ImpactNapkinSketch.astro";
import FeaturedCaseStudy from "@/components/case-study/FeaturedCaseStudy.astro";
import SkillsGroupedTags from "@/components/skills/SkillsGroupedTags.astro";
import SkillsOrbitRings from "@/components/skills/SkillsOrbitRings.astro";
import SkillsToolShelf from "@/components/skills/SkillsToolShelf.astro";
import PrinciplesGrid from "@/components/principles/PrinciplesGrid.astro";
import PrinciplesMarquee from "@/components/principles/PrinciplesMarquee.astro";
import PrinciplesHandwritten from "@/components/principles/PrinciplesHandwritten.astro";
import PrinciplesPillCloud from "@/components/principles/PrinciplesPillCloud.astro";
import PrinciplesRadar from "@/components/principles/PrinciplesRadar.astro";
import PrinciplesFlipCards from "@/components/principles/PrinciplesFlipCards.astro";
import TimelineSubway from "@/components/timeline/TimelineSubway.astro";
import TimelineElevation from "@/components/timeline/TimelineElevation.astro";
import TimelineVertical from "@/components/timeline/TimelineVertical.astro";
import TimelineOrbit from "@/components/timeline/TimelineOrbit.astro";
import TimelineFilmStrip from "@/components/timeline/TimelineFilmStrip.astro";
import CareerDomainFilter from "@/components/timeline/CareerDomainFilter.astro";
import CareerImageLightbox from "@/components/timeline/CareerImageLightbox.astro";
import ProjectsAppStore from "@/components/projects/ProjectsAppStore.astro";
import ProjectsScreenshot from "@/components/projects/ProjectsScreenshot.astro";
import ProjectsProblemSolution from "@/components/projects/ProjectsProblemSolution.astro";
import ContactOpenDoor from "@/components/contact/ContactOpenDoor.astro";
import ContactTerminal from "@/components/contact/ContactTerminal.astro";
import ContactMinimalFooter from "@/components/contact/ContactMinimalFooter.astro";
import { education, profile } from "@/data/portfolio";

function defaultAttr(group: keyof typeof DEFAULT_VARIANTS, variant: string) {
  return DEFAULT_VARIANTS[group] === variant ? ({ "data-is-default": true } as const) : {};
}
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": "Ankush Bhargava",
      "url": "https://ankushbhargava.us",
      "image": "https://ankushbhargava.us/images/ankush-bhargava-profile.jpg",
      "jobTitle": "Product Manager & AI Builder",
      "description": "Entrepreneurial player-coach with 20+ years across Product, Engineering and Business. AI-enabled, data-fluent, patent holder.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "San Francisco Bay Area",
        "addressRegion": "CA",
        "addressCountry": "US"
      },
      "knowsAbout": ["Product Management", "Artificial Intelligence", "B2B Platforms", "Logistics Technology", "Software Engineering", "Startup Founding", "Agentic Workflows"],
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Product Manager",
        "occupationLocation": { "@type": "City", "name": "San Francisco Bay Area" },
        "skills": "Product Management, Artificial Intelligence, B2B Platforms, Logistics Technology, Agentic Workflows"
      },
      "alumniOf": [
        { "@type": "Organization", "name": "Walmart" },
        { "@type": "Organization", "name": "University of Michigan" }
      ],
      "award": [
        "US Utility Patent — Inventory Management",
        "US Utility Patent — Delivery Logistics"
      ],
      "sameAs": [
        "https://linkedin.com/in/ankushbhargava",
        "https://github.com/ankush2kn",
        "https://productlogistics.beehiiv.com/",
        "https://x.com/TheKushBhargava"
      ]
    }
  })} />

  <!-- HERO VARIANTS -->
  <div data-variant-group="Hero" data-variant="A" {...defaultAttr("Hero", "A")}>
    <HeroAnimatedIntro />
  </div>
  <div data-variant-group="Hero" data-variant="B" {...defaultAttr("Hero", "B")}>
    <HeroSplitScreen />
  </div>
  <div data-variant-group="Hero" data-variant="C" {...defaultAttr("Hero", "C")}>
    <HeroBusinessCard />
  </div>

  <HeroBio />

  <!-- IMPACT VARIANTS -->
  <div data-variant-group="Impact" data-variant="A" {...defaultAttr("Impact", "A")}>
    <ImpactMetricCards />
  </div>
  <div data-variant-group="Impact" data-variant="B" {...defaultAttr("Impact", "B")}>
    <ImpactTickerStrip />
  </div>
  <div data-variant-group="Impact" data-variant="C" {...defaultAttr("Impact", "C")}>
    <ImpactNapkinSketch />
  </div>

  <FeaturedCaseStudy />

  <!-- PRINCIPLES VARIANTS -->
  <div data-variant-group="Principles" data-variant="A" {...defaultAttr("Principles", "A")}>
    <PrinciplesGrid />
  </div>
  <div data-variant-group="Principles" data-variant="B" {...defaultAttr("Principles", "B")}>
    <PrinciplesMarquee />
  </div>
  <div data-variant-group="Principles" data-variant="C" {...defaultAttr("Principles", "C")}>
    <PrinciplesHandwritten />
  </div>
  <div data-variant-group="Principles" data-variant="D" {...defaultAttr("Principles", "D")}>
    <PrinciplesPillCloud />
  </div>
  <div data-variant-group="Principles" data-variant="E" {...defaultAttr("Principles", "E")}>
    <PrinciplesRadar />
  </div>
  <div data-variant-group="Principles" data-variant="F" {...defaultAttr("Principles", "F")}>
    <PrinciplesFlipCards />
  </div>

  <!-- MY JOURNEY -->
  <section id="journey" class="pt-12 pb-20 px-6 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">My Journey</h2>
        <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">
          20+ years across startups and enterprise operations, in product, operations and engineering.
          From building code to building organizations.
        </p>
        <CareerDomainFilter />
      </div>

      <!-- TIMELINE VARIANTS -->
      <div data-variant-group="Timeline" data-variant="Subway" {...defaultAttr("Timeline", "Subway")}>
        <TimelineSubway />
      </div>
      <div data-variant-group="Timeline" data-variant="Elevation" {...defaultAttr("Timeline", "Elevation")}>
        <TimelineElevation />
      </div>
      <div data-variant-group="Timeline" data-variant="Vertical" {...defaultAttr("Timeline", "Vertical")}>
        <TimelineVertical />
      </div>
      <div data-variant-group="Timeline" data-variant="Orbit" {...defaultAttr("Timeline", "Orbit")}>
        <TimelineOrbit />
      </div>
      <div data-variant-group="Timeline" data-variant="FilmStrip" {...defaultAttr("Timeline", "FilmStrip")}>
        <TimelineFilmStrip />
      </div>

      <!-- Education -->
      <div class="mt-20 max-w-md mx-auto w-full">
        <h2 class="text-base uppercase tracking-widest text-[var(--color-text-secondary)] mb-6 text-center">Education</h2>
        <div class="space-y-4">
          {education.map((edu) => (
            <div class="flex items-start gap-4 bg-[var(--color-card-bg)] border border-[var(--color-border)] rounded-xl p-4">
              <div class="w-14 h-14 shrink-0 rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-secondary)] flex items-center justify-center">
                <img src={edu.logoSrc} alt={edu.logoAlt} class="w-full h-full object-contain p-1" width="56" height="56" loading="lazy" />
              </div>
              <div>
                <h3 class="text-sm font-bold">{edu.degree}</h3>
                <p class="text-xs text-[var(--color-text-secondary)]">{edu.focus}</p>
                <p class="text-xs text-[var(--color-text-secondary)]">{edu.school}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <CareerImageLightbox />

  <!-- MY LAB -->
  <section id="lab" class="pt-12 pb-20 px-6 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">My Lab</h2>
        <p class="max-w-5xl mx-auto text-[var(--color-text-secondary)] leading-relaxed">
          Post-Walmart, I established a high-velocity R&D sandbox to build with agentic workflows and GenAI.<br />
          These are live products built end-to-end.
        </p>
      </div>

      <!-- PROJECT VARIANTS -->
      <div data-variant-group="Projects" data-variant="A" {...defaultAttr("Projects", "A")}>
        <ProjectsAppStore />
      </div>
      <div data-variant-group="Projects" data-variant="B" {...defaultAttr("Projects", "B")}>
        <ProjectsScreenshot />
      </div>
      <div data-variant-group="Projects" data-variant="C" {...defaultAttr("Projects", "C")}>
        <ProjectsProblemSolution />
      </div>

    </div>
  </section>

  <!-- SKILLS VARIANTS -->
  <div data-variant-group="Skills" data-variant="A" {...defaultAttr("Skills", "A")}>
    <SkillsGroupedTags />
  </div>
  <div data-variant-group="Skills" data-variant="B" {...defaultAttr("Skills", "B")}>
    <SkillsOrbitRings />
  </div>
  <div data-variant-group="Skills" data-variant="C" {...defaultAttr("Skills", "C")}>
    <SkillsToolShelf />
  </div>

  <!-- Contact scroll anchor (used by HeroBio "connect" link) -->
  <div id="contact"></div>

  <!-- CONTACT VARIANTS -->
  <div data-variant-group="Contact" data-variant="A" {...defaultAttr("Contact", "A")}>
    <ContactOpenDoor />
  </div>
  <div data-variant-group="Contact" data-variant="B" {...defaultAttr("Contact", "B")}>
    <ContactTerminal />
  </div>
  <div data-variant-group="Contact" data-variant="C" {...defaultAttr("Contact", "C")}>
    <ContactMinimalFooter />
  </div>

  <ContactMinimalFooter />
</Layout>
